.category-container {
  margin-top: 30rpx;
  display: flex;
  gap: 24rpx;
}

.category-item {
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: rgba(240, 246, 244, 0.8);
  border-radius: 28rpx;
  padding: 0 22rpx;
  border: 2rpx solid #ffffff;
  height: 70rpx;
}

.category-image {
  width: 100%;
  height: 140rpx;
  border-radius: 20rpx;
  display: block;
  background-color: rgba(19, 78, 53, 0.12);
}

.category-name {
  font-size: 28rpx;
  color: #888888;
  text-align: center;
  line-height: 1.3;
}

.category-item.active {
  background-image: linear-gradient(
    to bottom,
    rgba(19, 78, 53, 0.85) 0%,
    rgba(27, 94, 32, 0.85) 100%
  );
  border-color: rgba(255, 255, 255, 0.95);
}

.category-item.active .category-name {
  color: #ffffff;
  font-weight: 500;
}
