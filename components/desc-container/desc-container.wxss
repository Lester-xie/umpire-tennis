.desc-root {
  margin-top: 28rpx;
}
.desc-root,
.desc-measure {
  width: 100%;
}

.desc-container {
  position: relative;
  width: 100%;
  margin: 0;
  box-sizing: border-box;
  overflow: hidden;
  /* 与 desc-container.js 中 aspectRatio 一致 */
  aspect-ratio: 1.9230769230769231 / 1;
}

.desc {
  display: block;
  border-radius: 26rpx;
  width: 100%;
  height: 100%;
}

.svg-icon {
  width: 60rpx;
  height: 60rpx;
}

.tennis {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 10;
  will-change: transform;
}

.logo {
  position: absolute;
  right: 16rpx;
  bottom: 0rpx;
  width: 160rpx;
  height: 160rpx;
  z-index: 10;
}