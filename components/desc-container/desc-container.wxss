.desc-container {
  position: relative;
  margin-top: 28rpx;
  margin-left: auto;
  margin-right: auto;
  padding-bottom: 40rpx;
  border-bottom: 2rpx solid #ffffff;
}

.desc {
  display: block;
  border-radius: 36rpx;
}

.svg-icon {
  width: 60rpx;
  height: 60rpx;
}

.tennis {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 10;
  will-change: transform;
}
