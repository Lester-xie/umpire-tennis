.desc-container {
  position: relative;
  margin-top: 14px;
  margin-left: auto;
  margin-right: auto;
  padding-bottom: 20px;
  border-bottom: 1px solid #ffffff;
}

.desc {
  display: block;
  border-radius: 16px;
}

.svg-icon {
  width: 30px;
  height: 30px;
}

.tennis {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 10;
  will-change: transform;
}
