/* pages/components/header.wxss */
.header {
  color: #134E35;
  padding-bottom: 10px;
  z-index: 100;
}
.header-top {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}
.back-button {
  position: absolute;
  left: 0;
  top: 0;
  width: 36px;
  height: 36px;
  background-color: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}
.back-button:active {
  background-color: #E0E0E0;
}
.back-icon {
  width: 18px;
  height: 15px;
}
.switch-account-icon {
  width: 20px;
  height: 20px;
}
.location-button {
  position: absolute;
  left: 0;
  top: 0;
  width: 36px;
  height: 36px;
  background-color: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.location-button:active {
  background-color: #E0E0E0;
}
.location-icon {
  width: 20px;
  height: 20px;
}
.title {
  text-align: center;
  font-size: 16px;
  font-weight: 500;
  margin-top: 5px;
  height: 20px;
}
.desc-container {
  position: relative;
  margin-top: 14px;
  margin-left: auto;
  margin-right: auto;
  padding-bottom: 20px;
  border-bottom: 1px solid #ffffff;
}

.desc {
  display: block;
  border-radius: 16px;
}

.svg-icon {
  width: 30px;
  height: 30px;
}

.tennis {
  position: absolute;
  left: 0;
  top: 0;
  z-index: 10;
  will-change: transform;
}