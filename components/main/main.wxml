<view class="main-container">
  <view class="main-item" bindtap="handleBookingClick">
    <view class="main-item-image-container">
      <image class="main-item-image" src="/assets/images/tennis-court.svg" mode="aspectFit"></image>
    </view>
    <view class="main-item-title">预订球场</view>
  </view>
  <view class="main-item" bindtap="handleGroupBuyClick">
    <view class="main-item-image-container">
      <image class="main-item-image" src="/assets/images/tennis-racket.svg" mode="aspectFit"></image>
    </view>
    <view class="main-item-title">全部团购</view>
  </view>
</view>