.goods-container {
  margin-top: 40rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.goods-item {
  box-sizing: border-box;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  background-color: rgba(240, 246, 244, 0.8);
  border-radius: 28rpx;
  padding: 16rpx;
  border: 2rpx solid #ffffff;
  overflow: hidden;
}

.goods-image {
  width: 100%;
  height: 300rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.goods-info {
  margin: 16rpx -16rpx 0;
  padding: 16rpx 16rpx 0;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 2rpx solid #134E35;
}

.arrow-icon {
  width: 28rpx;
  height: 28rpx;
  transform: rotate(180deg);
}

.goods-title {
  font-size: 28rpx;
  color: #000000;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.goods-empty {
  margin-top: 40rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #888888;
  background-color: rgba(240, 246, 244, 0.6);
  border-radius: 28rpx;
  border: 2rpx solid #ffffff;
}
