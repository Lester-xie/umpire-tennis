<wxs src="../../wxs/string.wxs" module="str" />
<view class="container">
  <lottie-loading visible="{{lottieLoadingVisible}}" />
  <header showBackButton="{{true}}" title="预约场地" />
  <view class="content" style="height: {{contentHeight}}px; padding-bottom: {{selectedSlots.length > 0 || (isManagerUser && selectedUnlockSlots.length > 0) ? '140rpx' : '40rpx'}};">
    <view
      class="content-header"
      hover-class="content-header-title--hover"
      hover-start-time="20"
      hover-stay-time="100"
      bindtap="handleContentHeaderTitleTap"
    >
      <image class="content-header-icon" src="/assets/images/location.png" mode="aspectFit"></image>
      {{selectedVenueName}}
    </view>

    <scroll-view class="content-calendar" scroll-x="true" enable-flex="true">
      <view class="content-calendar-scroll">
        <view 
          class="content-calendar-item" 
          wx:for="{{dateList}}" 
          wx:key="dateStr"
          data-datestr="{{item.dateStr}}"
          bindtap="handleDateClick"
        >
          <view class="date-weekday">{{item.weekday}}</view>
          <view class="date-month-day {{selectedDate === item.dateStr ? 'active' : ''}} {{rippleDate === item.dateStr ? 'ripple' : ''}}">
            <view class="date-text">{{item.monthDay}}</view>
            <view class="ripple-effect" wx:if="{{rippleDate === item.dateStr}}"></view>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="content-time">
      <!-- 可滚动的区域 -->
      <scroll-view class="content-time-scroll" scroll-x="true" scroll-y="true" enable-flex="true" show-scrollbar="{{false}}">
        <view class="time-table">
          <!-- 第一行：时间列头部 + 场地头部 -->
          <view class="time-table-header">
            <!-- 固定的时间列头部 -->
            <view class="time-column-fixed">
              <view class="time-header-fixed"></view>
            </view>
            <!-- 固定的场地头部 -->
            <view class="court-header-row">
              <view class="court-header" wx:for="{{courts}}" wx:key="id">
                {{item.name}}
              </view>
            </view>
          </view>
          
          <!-- 内容行：时间列 + 场地内容 -->
          <view class="time-table-content">
            <!-- 固定的时间列 -->
            <view class="time-column-fixed">
              <view class="time-slot-fixed" wx:for="{{timeSlots}}" wx:key="time">
                {{item.time}}
              </view>
            </view>
            <!-- 可滚动的内容区域 -->
            <view class="court-content-row">
              <view class="court-column" wx:for="{{courts}}" wx:key="id">
                <view class="court-slots court-slots--stacked">
                  <block wx:for="{{item.slots}}" wx:for-item="slot" wx:for-index="slotIndex" wx:key="slotIndex">
                    <view 
                      wx:if="{{!slot.coachMergeSkip && slot.available}}"
                      class="time-slot-cell available {{selectedSlotsMap[item.id + '-' + slotIndex] ? 'active' : ''}} {{rippleSlot && rippleSlot.courtId === item.id && rippleSlot.slotIndex === slotIndex ? 'ripple' : ''}}"
                      style="{{slot.slotStyle}}"
                      data-courtid="{{item.id}}"
                      data-slotindex="{{slotIndex}}"
                      bindtap="handleSlotClick"
                    >
                      <view class="slot-text">
                        <text class="slot-price">预约</text>
                      </view>
                      <view class="ripple-effect" wx:if="{{rippleSlot && rippleSlot.courtId === item.id && rippleSlot.slotIndex === slotIndex}}"></view>
                    </view>
                    <view 
                      wx:elif="{{!slot.coachMergeSkip && !slot.available && slot.venueLock && isManagerUser && !slot.past}}"
                      class="time-slot-cell available slot-venue-lock-selectable {{selectedUnlockSlotsMap[item.id + '-' + slotIndex] ? 'active' : ''}} {{rippleSlot && rippleSlot.courtId === item.id && rippleSlot.slotIndex === slotIndex ? 'ripple' : ''}}"
                      style="{{slot.slotStyle}}"
                      data-courtid="{{item.id}}"
                      data-slotindex="{{slotIndex}}"
                      data-holdids="{{slot.coachHoldIdsStr}}"
                      bindtap="handleVenueLockSlotClick"
                    >
                      <view class="slot-text">
                        <text class="slot-price">已锁定</text>
                      </view>
                      <view class="ripple-effect" wx:if="{{rippleSlot && rippleSlot.courtId === item.id && rippleSlot.slotIndex === slotIndex}}"></view>
                    </view>
                    <view 
                      wx:elif="{{!slot.coachMergeSkip && !slot.available}}"
                      class="time-slot-cell {{slot.past ? 'slot-past' : ''}} {{slot.booked ? 'slot-occupied' : ''}} {{slot.bookedByCoach ? 'slot-coach-hold' : ''}}"
                      style="{{slot.slotStyle}}"
                    >
                      <block wx:if="{{slot.past}}">
                        <text class="slot-booked">不可预定</text>
                      </block>
                      <block wx:elif="{{slot.venueLock}}">
                        <text class="slot-booked">已占用</text>
                      </block>
                      <block wx:elif="{{slot.bookedByCoach}}">
                        <view
                          class="slot-coach-inner"
                          catchtap="handleCoachHoldCellTap"
                          data-holdids="{{slot.coachHoldIdsStr}}"
                          data-canmanage="{{slot.canManageCoachHold}}"
                          data-released="{{slot.coachSessionReleased}}"
                          data-lessontype="{{slot.prefillLessonType}}"
                          data-pairmode="{{slot.prefillPairMode}}"
                          data-groupmode="{{slot.prefillGroupMode}}"
                          data-minparticipants="{{slot.coachMinParticipants}}"
                          data-maxparticipants="{{slot.prefillMaxParticipants}}"
                          data-refundhours="{{slot.prefillRefundHours}}"
                          data-courtid="{{item.id}}"
                          data-slotindex="{{slotIndex}}"
                        >
                          <text class="slot-coach-purpose">{{slot.coachPurpose}}</text>
                          <text class="slot-coach-name" wx:if="{{slot.prefillCoachName}}">{{str.truncate(slot.prefillCoachName, 4)}}</text>
                          <text class="slot-coach-cap" wx:if="{{slot.coachCapacityLimit > 0}}">名额 {{slot.coachJoinedCount}}/{{slot.coachCapacityLimit}}</text>
                        </view>
                      </block>
                      <block wx:elif="{{slot.booked}}">
                        <text class="slot-booked">已订</text>
                      </block>
                      <block wx:else>
                        <text class="slot-booked">已约</text>
                      </block>
                    </view>
                  </block>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
    <view class="content-footer" wx:if="{{selectedSlots.length > 0 || (isManagerUser && selectedUnlockSlots.length > 0)}}">
      <view class="content-footer-actions">
        <view
          wx:if="{{isManagerUser && selectedSlots.length > 0}}"
          class="content-footer-lock-button"
          bindtap="handleLockVenueSlots"
        >
          <text class="content-footer-lock-button-text">锁场</text>
        </view>
        <view
          wx:if="{{isManagerUser && selectedUnlockSlots.length > 0}}"
          class="content-footer-lock-button"
          bindtap="handleUnlockVenueSlots"
        >
          <text class="content-footer-lock-button-text">解锁</text>
        </view>
        <view class="content-footer-right">
          <view wx:if="{{selectedSlots.length > 0}}" class="content-footer-right-button" bindtap="handleNextToPurpose">
            <text class="content-footer-right-button-text">下一步</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="purpose-mask" wx:if="{{showPurposeSheet}}" catchtap="closePurposeSheet"></view>
  <view class="purpose-sheet" wx:if="{{showPurposeSheet}}">
    <view class="purpose-sheet-title">{{ purposeSheetMode === 'edit' ? '更改场地类型' : '填写场地用途' }}</view>
    <block wx:if="{{purposeShowStandardTypes || showOpenPlayChip}}">
      <view class="purpose-section-label">课程类型</view>
      <view class="purpose-chip-row">
        <view class="purpose-chip {{lessonType === 'experience' ? 'purpose-chip--on' : ''}}" data-v="experience" bindtap="selectLessonType">体验课</view>
        <view class="purpose-chip {{lessonType === 'regular' ? 'purpose-chip--on' : ''}}" data-v="regular" bindtap="selectLessonType">正课</view>
        <view class="purpose-chip {{lessonType === 'group' ? 'purpose-chip--on' : ''}}" data-v="group" bindtap="selectLessonType">团课</view>
        <view wx:if="{{showOpenPlayChip}}" class="purpose-chip {{lessonType === 'open_play' ? 'purpose-chip--on' : ''}}" data-v="open_play" bindtap="selectLessonType">畅打</view>
      </view>
    </block>
    <block wx:if="{{isManagerUser && (lessonType === 'experience' || lessonType === 'regular' || lessonType === 'group')}}">
      <view class="purpose-section-label">指定教练（可选）</view>
      <block wx:if="{{coachPickerLabels.length}}">
        <picker mode="selector" range="{{coachPickerLabels}}" value="{{coachPickerIndex}}" bindchange="onCoachPickerChange">
          <view class="purpose-coach-pick">{{coachPickerLabels[coachPickerIndex]}}</view>
        </picker>
      </block>
      <view wx:else class="purpose-coach-pick purpose-coach-pick--empty" bindtap="onCoachPickEmptyTap">暂无可选教练 · 点击重试</view>
      <view class="purpose-open-hint">未选择时占用记在本人管理员账号下</view>
    </block>
    <view wx:if="{{isManagerUser && lessonType === 'open_play'}}" class="purpose-open-hint">畅打可不指定教练，占用记在本人管理员账号下</view>
    <block wx:if="{{lessonType === 'experience' || lessonType === 'regular'}}">
      <view class="purpose-section-label">规模</view>
      <view class="purpose-chip-row">
        <view
          wx:for="{{purposePairScales}}"
          wx:key="id"
          class="purpose-chip {{pairMode === item.modeCode ? 'purpose-chip--on' : ''}}"
          data-kind="pair"
          data-code="{{item.modeCode}}"
          bindtap="selectPurposeScale"
        >{{item.name}}</view>
      </view>
    </block>
    <block wx:if="{{lessonType === 'experience' || lessonType === 'regular'}}">
      <view class="purpose-section-label">退课规则</view>
      <view class="purpose-enroll-grid">
        <view class="purpose-enroll-row">
          <text class="purpose-enroll-label">开课前（小时）</text>
          <view class="purpose-enroll-field">
            <input class="purpose-enroll-input purpose-enroll-input--narrow" type="number" value="{{refundHoursBeforeStart}}" bindinput="onRefundHoursInput" />
            <text class="purpose-enroll-unit">小时</text>
          </view>
        </view>
      </view>
      <view class="purpose-enroll-hint">距首场开始不足该时间不可取消；默认 6 小时</view>
    </block>
    <block wx:if="{{lessonType === 'group' || lessonType === 'open_play'}}">
      <view class="purpose-section-label">人数与规则</view>
      <view class="purpose-enroll-grid">
        <view class="purpose-enroll-row">
          <text class="purpose-enroll-label">最少人数</text>
          <input class="purpose-enroll-input" type="number" value="{{minParticipants}}" bindinput="onMinParticipantsInput" />
        </view>
        <view class="purpose-enroll-row">
          <text class="purpose-enroll-label">最多人数</text>
          <input class="purpose-enroll-input" type="number" value="{{maxParticipants}}" bindinput="onMaxParticipantsInput" />
        </view>
        <view class="purpose-enroll-row">
          <text class="purpose-enroll-label">开课前（小时）</text>
          <view class="purpose-enroll-field">
            <input class="purpose-enroll-input purpose-enroll-input--narrow" type="number" value="{{refundHoursBeforeStart}}" bindinput="onRefundHoursInput" />
            <text class="purpose-enroll-unit">小时</text>
          </view>
        </view>
      </view>
      <view class="purpose-enroll-hint">该时间前可退课；到达该时刻若已付人数仍少于最少人数，将自动取消并退款</view>
    </block>
    <view class="purpose-section-label">会员支付（元/次）</view>
    <input
      class="purpose-member-price-input"
      type="digit"
      value="{{purposeMemberPriceYuan}}"
      placeholder="{{purposeMemberPricePlaceholder}}"
      bindinput="onPurposeMemberPriceInput"
    />
    <view class="purpose-hint">{{ purposeSheetMode === 'edit' ? '保存后会员在订场页将看到更新后的用途说明' : '确定后该时段将对会员显示为已占用，不可再订' }}</view>
    <view class="purpose-sheet-actions">
      <view class="purpose-btn purpose-btn--ghost" bindtap="closePurposeSheet">取消</view>
      <view class="purpose-btn purpose-btn--primary" bindtap="confirmPurposeSheet">确定</view>
    </view>
  </view>
</view>
