<view class="profile-container">
  <view class="header-wrapper">
    <header hideDesc="{{true}}" showBackButton="{{true}}" title="我的场地占用" />
  </view>
  <scroll-view
    class="content-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    style="margin-top: {{headerHeight}}px; height: {{contentHeight}}px;"
  >
    <view class="content-wrapper">
      <view class="card section-card" wx:if="{{isCoach || isManager}}">
        <view class="section-list" wx:if="{{coachHolds.length > 0}}">
          <view class="list-item coach-hold-item" wx:for="{{coachHolds}}" wx:key="_id">
            <view class="item-main">
              <view class="coach-hold-line coach-hold-line--strong">{{item.displayDate}} {{item.timeRange}}</view>
              <view class="coach-hold-line">{{item.venueLine}} · {{item.courtLabel}}</view>
              <view class="coach-hold-line coach-hold-purpose" wx:if="{{item.purposeLine}}">{{item.purposeLine}}</view>
            </view>
            <view
              class="coach-hold-cancel"
              data-holdid="{{item._id}}"
              catchtap="handleCancelCoachHold"
            >取消</view>
          </view>
        </view>
        <view class="empty-tip coach-hold-empty" wx:else>
          <text>暂无占用记录</text>
        </view>
      </view>
      <view class="placeholder" style="height: {{placeholderHeight}}px;"></view>
    </view>
  </scroll-view>
</view>
