.profile-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbefd0 0%, #dbefd0 55%, #dae4de 100%);
  box-sizing: border-box;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  width: 100%;
}

.content-wrapper {
  padding: 32rpx;
}

/* 卡片通用样式 */
.card {
  background-color: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx;
  min-height: 160rpx;
  position: relative;
}

.user-avatar-wrapper {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F2F6F3 0%, #E8EFEB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.user-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  box-sizing: border-box;
  border: 4rpx solid #E8EFEB;
}

.user-info {
  flex: 1;
  margin-left: 32rpx;
  min-width: 0;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #134E35;
  line-height: 1.3;
}

.user-desc-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
  min-width: 0;
}

.user-desc {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #888;
  line-height: 1.4;
}

.user-identity-wrapper {
  flex-shrink: 0;
  margin-left: 16rpx;
  padding: 4rpx;
  font-size: 32rpx;
  color: #134E35;
  background: #a1d3a2;
  border: 2rpx solid #134E35;
  border-radius: 12rpx;
}

.user-identity {
  border: 1rpx solid #134E35;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.user-vip-icon {
  height: 100rpx;
  width: auto;
  max-width: 176rpx;
  flex-shrink: 0;
  display: block;
}

.user-arrow {
  padding: 16rpx;
  flex-shrink: 0;
}

/* 未登录时，透明覆盖按钮：点击 user-card 直接触发 getPhoneNumber */
.user-card-auth-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  border: none;
  border-radius: 28rpx;
  padding: 0;
  margin: 0;
  opacity: 0;
  z-index: 2;
}

.booking-court-wrapper {
  margin-bottom: 32rpx;
}

.coach-book-card {
  padding: 36rpx 32rpx;
}

.coach-book-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #134e35;
  margin-bottom: 16rpx;
}

.coach-book-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 28rpx;
}

.coach-book-btn {
  text-align: center;
  padding: 22rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #134e35 0%, #1a6b4a 100%);
  border-radius: 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(19, 78, 53, 0.28);
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
  transform: rotate(180deg);
}

.menu-card {
  margin-bottom: 32rpx;
  padding: 0;
  overflow: hidden;
}

.menu-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 36rpx 32rpx;
  min-height: 96rpx;
  box-sizing: border-box;
}

.menu-row:active {
  background: rgba(19, 78, 53, 0.06);
}

.menu-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #134e35;
}

.menu-arrow {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  transform: rotate(180deg);
  opacity: 0.45;
}

.menu-divider {
  height: 2rpx;
  margin: 0 32rpx;
  background: #f0f0f0;
}

.placeholder {
  width: 100%;
}

/* 登录提示弹窗 */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal {
  width: 560rpx;
  background-color: #fff;
  border-radius: 28rpx;
  padding: 48rpx;
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.login-modal-desc {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.login-modal-btns {
  display: flex;
  gap: 24rpx;
}

.login-modal-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 20rpx;
  border: none;
  margin: 0;
}

.login-modal-btn::after {
  border: none;
}

.login-modal-btn.cancel {
  background-color: #F0F0F0;
  color: #666;
}

.login-modal-btn.confirm {
  background: linear-gradient(135deg, #134E35 0%, #1a6b4a 100%);
  color: #fff;
  font-weight: 500;
}

