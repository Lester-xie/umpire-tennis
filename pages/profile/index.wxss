.profile-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbefd0 0%, #dbefd0 55%, #dae4de 100%);
  box-sizing: border-box;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

/* 滚动区 */
.profile-scroll {
  flex: 1;
  width: 100%;
}

.profile-body {
  padding: 8rpx 32rpx 32rpx;
}

/* 头像英雄区 */
.profile-hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 40rpx;
}

.profile-hero-deco {
  position: absolute;
  top: 32rpx;
  font-size: 36rpx;
  color: #134e35;
  opacity: 0.35;
  pointer-events: none;
}

.profile-hero-deco--l {
  left: 48rpx;
}

.profile-hero-deco--r {
  top: 80rpx;
  right: 48rpx;
}

.profile-icon {
  width: 100rpx;
  height: 100rpx;
  position: absolute;
  top: 0;
  left: 0;
}

.profile-avatar-wrap {
  position: relative;
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
  background: #fff;
  border: 2rpx solid #134e35;
  box-shadow: 0 8rpx 32rpx rgba(19, 78, 53, 0.12);
  overflow: hidden;
}

.profile-avatar {
  width: 176rpx;
  height: 176rpx;
  border-radius: 50%;
}

.profile-avatar--placeholder {
  padding: 36rpx;
  box-sizing: border-box;
}

.profile-avatar-auth-btn {
  position: absolute;
  left: 0;
  top: 0;
  width: 176rpx !important;
  height: 100%;
  opacity: 0;
  z-index: 2;
}

.profile-name {
  margin-top: 28rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #134e35;
  letter-spacing: 0.02em;
}

.profile-badge {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #134e35;
  padding: 6rpx 20rpx;
  background: rgba(19, 78, 53, 0.1);
  border-radius: 999rpx;
}

/* 课时卡片：外层间距；内层由 card 组件提供描边与双层底 */
/* card-bg 向右下错位 8rpx，需留出空隙，否则在 scroll-view 内易被裁剪 */
.profile-reward-section {
  margin-bottom: 28rpx;
  width: 100%;
  padding-right: 8rpx;
  padding-bottom: 8rpx;
  box-sizing: border-box;
}

.profile-reward-card {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 28rpx 32rpx;
  box-sizing: border-box;
  line-height: normal;
}

.profile-reward-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #e8f5e9 0%, #c8e6c9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.profile-reward-icon-star {
  font-size: 44rpx;
  color: #ffc107;
  line-height: 1;
}

.profile-reward-text {
  flex: 1;
  min-width: 0;
}

.profile-reward-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.profile-reward-value-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8rpx;
}

.profile-reward-star {
  font-size: 28rpx;
  color: #ffc107;
}

.profile-reward-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.1;
}

.profile-reward-unit {
  font-size: 26rpx;
  color: #888;
  font-weight: 500;
}

.profile-reward-btn {
  flex-shrink: 0;
  padding: 18rpx 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(180deg, #ff9f43 0%, #e67e22 100%);
  border-radius: 999rpx;
  box-shadow: 0 6rpx 20rpx rgba(230, 126, 34, 0.35);
}

.profile-reward-btn:active {
  opacity: 0.92;
}

/* 菜单 */
.profile-menu-card {
  overflow: hidden;
}

.profile-menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  height: 100rpx;
  box-sizing: border-box;
}

.profile-menu-item--hover {
  background: rgba(19, 78, 53, 0.05);
}

.profile-menu-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 24rpx;
  border-radius: 14rpx;
  background: rgba(19, 78, 53, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.profile-menu-icon-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #134e35;
  line-height: 1;
}

.profile-menu-label {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.profile-menu-sep {
  width: 2rpx;
  height: 80rpx;
  background: #134e35;
  margin-right: 20rpx;
  flex-shrink: 0;
  position: relative;
  top: 12rpx;
}

.profile-menu-divider {
  height: 2rpx;
  margin-left: 28rpx;
  background: #134e35;
}

.profile-footer-space {
  width: 100%;
}

.profile-menu-arrow {
  width: 28rpx;
  height: 28rpx;
  transform: rotate(180deg);
}