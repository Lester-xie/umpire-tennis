.profile-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbefd0 0%, #dbefd0 55%, #dae4de 100%);
  box-sizing: border-box;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 16px;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  width: 100%;
}

.content-wrapper {
  padding: 16px;
}

/* 卡片通用样式 */
.card {
  background-color: #fff;
  border-radius: 14px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  padding: 20px;
  min-height: 80px;
  position: relative;
}

.user-avatar-wrapper {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #F2F6F3 0%, #E8EFEB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.user-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  box-sizing: border-box;
  border: 2px solid #E8EFEB;
}

.user-info {
  flex: 1;
  margin-left: 16px;
  min-width: 0;
}

.user-name {
  font-size: 17px;
  font-weight: 600;
  color: #134E35;
  line-height: 1.3;
}

.user-desc {
  font-size: 13px;
  color: #888;
  margin-top: 4px;
}

.user-arrow {
  padding: 8px;
  flex-shrink: 0;
}

/* 未登录时，透明覆盖按钮：点击 user-card 直接触发 getPhoneNumber */
.user-card-auth-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  border: none;
  border-radius: 14px;
  padding: 0;
  margin: 0;
  opacity: 0;
  z-index: 2;
}

.arrow-icon {
  width: 16px;
  height: 16px;
  transform: rotate(180deg);
}

/* 区块卡片 */
.section-card {
  margin-bottom: 16px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 12px;
  margin-bottom: 12px;
  border-bottom: 1px solid #F0F0F0;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #134E35;
}

.section-count {
  font-size: 13px;
  color: #999;
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 12px;
  background-color: #F7F9FF;
  border-radius: 10px;
}

.court-item .item-main {
  flex: 1;
  min-width: 0;
}

.court-item .item-date {
  font-size: 14px;
  font-weight: 500;
  color: #134E35;
  margin-bottom: 4px;
}

.court-item .item-summary {
  font-size: 12px;
  color: #666;
}

.goods-item .goods-thumb {
  width: 56px;
  height: 56px;
  border-radius: 8px;
  flex-shrink: 0;
}

.goods-item .item-main {
  flex: 1;
  margin-left: 12px;
  min-width: 0;
}

.goods-item .item-desc {
  font-size: 14px;
  color: #134E35;
  line-height: 1.4;
}

.goods-item .item-time {
  font-size: 12px;
  color: #999;
  margin-top: 4px;
}

.item-price {
  font-size: 15px;
  font-weight: 600;
  color: #134E35;
  flex-shrink: 0;
  margin-left: 8px;
}

.empty-tip {
  padding: 24px;
  text-align: center;
  font-size: 14px;
  color: #999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.empty-link {
  font-size: 14px;
  color: #134E35;
  font-weight: 500;
  text-decoration: none;
}

.placeholder {
  width: 100%;
}

/* 登录提示弹窗 */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal {
  width: 280px;
  background-color: #fff;
  border-radius: 14px;
  padding: 24px;
}

.login-modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 12px;
}

.login-modal-desc {
  font-size: 15px;
  color: #666;
  text-align: center;
  margin-bottom: 24px;
  line-height: 1.5;
}

.login-modal-btns {
  display: flex;
  gap: 12px;
}

.login-modal-btn {
  flex: 1;
  padding: 12px;
  text-align: center;
  font-size: 15px;
  border-radius: 10px;
  border: none;
  margin: 0;
}

.login-modal-btn::after {
  border: none;
}

.login-modal-btn.cancel {
  background-color: #F0F0F0;
  color: #666;
}

.login-modal-btn.confirm {
  background: linear-gradient(135deg, #134E35 0%, #1a6b4a 100%);
  color: #fff;
  font-weight: 500;
}

