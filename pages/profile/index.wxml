<view class="profile-container">
  <view class="header-wrapper">
    <header
      hideDesc="{{true}}"
      showSwitchAccountButton="{{isLoggedIn && userPhone}}"
      bind:switchaccount="onSwitchAccount"
    />
  </view>
  <scroll-view
    class="content-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    style="margin-top: {{headerHeight}}px; height: {{contentHeight}}px;"
  >
    <view class="content-wrapper">
      <!-- 用户信息卡片 -->
      <view class="card user-card" bindtap="handleUserCardTap">
        <view class="user-avatar-wrapper">
          <image
            wx:if="{{isLoggedIn}}"
            class="user-avatar"
            src="{{userAvatar || '/assets/images/tab-bar-user-active.svg'}}"
            mode="aspectFill"
          ></image>
          <image
            wx:else
            class="user-avatar"
            src="/assets/images/tab-bar-user-active.svg"
            mode="aspectFit"
          ></image>
        </view>
        <view class="user-info">
          <view class="user-name">{{userDisplayName}}</view>
          <view class="user-desc">{{isLoggedIn ? (userPhone || '欢迎使用昂湃网球') : '登录后查看订场与团购记录'}}</view>
        </view>
        <view class="user-arrow" wx:if="{{!isLoggedIn}}">
          <image class="arrow-icon" src="/assets/images/arrow.svg" mode="aspectFit"></image>
        </view>

        <!-- 未登录时：用透明按钮覆盖整个用户卡片，点击直接触发 getPhoneNumber -->
        <button
          wx:if="{{!isLoggedIn}}"
          class="user-card-auth-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onPhoneRegister"
        ></button>
      </view>

      <!-- 订场历史卡片 -->
      <view class="card section-card">
        <view class="section-header">
          <text class="section-title">订场历史</text>
          <text class="section-count">{{courtOrders.length}} 条</text>
        </view>
        <view class="section-list" wx:if="{{courtOrders.length > 0}}">
          <view
            class="list-item court-item"
            wx:for="{{courtOrders}}"
            wx:key="orderNumber"
          >
            <view class="item-main">
              <view class="item-date">{{item.formattedDate}}</view>
              <view class="item-summary">{{item.displaySummary}}</view>
            </view>
            <view class="item-price">¥ {{item.totalPrice}}</view>
          </view>
        </view>
        <view class="empty-tip" wx:else>
          <text>暂无订场记录</text>
          <navigator class="empty-link" url="/pages/booking/index" open-type="switchTab">去预订</navigator>
        </view>
      </view>

      <!-- 团购购买历史卡片 -->
      <view class="card section-card">
        <view class="section-header">
          <text class="section-title">团购历史</text>
          <text class="section-count">{{goodsOrders.length}} 条</text>
        </view>
        <view class="section-list" wx:if="{{goodsOrders.length > 0}}">
          <view
            class="list-item goods-item"
            wx:for="{{goodsOrders}}"
            wx:key="orderNumber"
          >
            <image class="goods-thumb" src="{{item.goodItem.image}}" mode="aspectFill"></image>
            <view class="item-main">
              <view class="item-desc">{{item.goodItem.desc}}</view>
              <view class="item-time">{{item.formattedTime}}</view>
            </view>
            <view class="item-price">¥ {{item.totalPrice}}</view>
          </view>
        </view>
        <view class="empty-tip" wx:else>
          <text>暂无团购记录</text>
          <navigator class="empty-link" url="/pages/group-buy/index">去团购</navigator>
        </view>
      </view>

      <view class="placeholder" style="height: {{placeholderHeight}}px;"></view>
    </view>
  </scroll-view>

</view>
