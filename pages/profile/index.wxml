<view class="profile-container">
  <lottie-loading visible="{{lottieLoadingVisible}}" />
  <view class="header-wrapper">
    <header
      showSwitchAccountButton="{{isLoggedIn && userPhone}}"
      bind:switchaccount="onSwitchAccount"
    />
  </view>
  <scroll-view
    class="content-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    style="margin-top: {{headerHeight}}px; height: {{contentHeight}}px;"
  >
    <view class="content-wrapper">
      <!-- 用户信息卡片 -->
      <view class="card user-card" bindtap="handleUserCardTap">
        <view class="user-avatar-wrapper">
          <image
            wx:if="{{isLoggedIn}}"
            class="user-avatar"
            src="{{ userAvatar || '/assets/images/default-avatar.jpg'}}"
            mode="aspectFill"
          ></image>
          <image
            wx:else
            class="user-avatar"
            src="/assets/images/tab-bar-user-active.svg"
            mode="aspectFit"
          ></image>
        </view>
        <view class="user-info">
          <view class="user-name">{{userDisplayName}}</view>
          <view class="user-desc-row">
            <view class="user-desc">{{isLoggedIn ? (userPhone || '欢迎使用昂湃网球') : '登录后查看订场与团购记录'}}</view>
          </view>
        </view>
        <view wx:if="{{userIdentity}}" class="user-identity-wrapper">
          <view class="user-identity">{{userIdentity}}</view>
        </view>
        <view class="user-arrow" wx:if="{{!isLoggedIn}}">
          <image class="arrow-icon" src="/assets/images/arrow.svg" mode="aspectFit"></image>
        </view>

        <!-- 未登录时：用透明按钮覆盖整个用户卡片，点击直接触发 getPhoneNumber -->
        <button
          wx:if="{{!isLoggedIn}}"
          class="user-card-auth-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="onPhoneRegister"
        ></button>
      </view>
      <view class="booking-court-wrapper" wx:if="{{isCoach || isManager}}">
        <view class="coach-book-card card">
          <view class="coach-book-desc">选择时段并填写用途后，该场地时段将对会员显示为已占用，无法预订。</view>
          <view class="coach-book-btn" bindtap="handleCoachBookCourt">预约场地</view>
        </view>
      </view>

      <view class="card menu-card">
        <!-- 仅教练可见；管理员不展示「我的场地占用」 -->
        <block wx:if="{{isCoach}}">
          <view class="menu-row" bindtap="goCoachHolds">
            <text class="menu-title">我的场地占用</text>
            <image class="menu-arrow" src="/assets/images/arrow.svg" mode="aspectFit"></image>
          </view>
          <view class="menu-divider"></view>
        </block>
        <view class="menu-row" bindtap="goCourtOrders">
          <text class="menu-title">订场历史</text>
          <image class="menu-arrow" src="/assets/images/arrow.svg" mode="aspectFit"></image>
        </view>
        <view class="menu-divider"></view>
        <view class="menu-row" bindtap="goGoodsOrders">
          <text class="menu-title">课程订单</text>
          <image class="menu-arrow" src="/assets/images/arrow.svg" mode="aspectFit"></image>
        </view>
        <view class="menu-divider"></view>
        <view class="menu-row" bindtap="goCourseHours">
          <text class="menu-title">我的课时</text>
          <image class="menu-arrow" src="/assets/images/arrow.svg" mode="aspectFit"></image>
        </view>
      </view>

      <view class="placeholder" style="height: {{placeholderHeight}}px;"></view>
    </view>
  </scroll-view>

</view>
