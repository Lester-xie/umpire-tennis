<view class="profile-page">
  <lottie-loading visible="{{lottieLoadingVisible}}" />

  <view class="header-wrapper">
    <header
      title="账户"
      showSwitchAccountButton="{{isLoggedIn && userPhone}}"
      bind:switchaccount="onSwitchAccount"
    />
  </view>

  <scroll-view
    class="profile-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    style="margin-top: {{headerHeight}}px; height: {{contentHeight}}px;"
  >
    <view class="profile-body">
      <!-- 头像区：居中 + 装饰 -->
      <view class="profile-hero">
        <view class="profile-hero-deco profile-hero-deco--l">✦</view>
        <view class="profile-hero-deco profile-hero-deco--r">✧</view>
        <view class="profile-avatar-wrap" bindtap="handleUserCardTap">
          <image
            wx:if="{{isLoggedIn}}"
            class="profile-avatar"
            src="{{ userAvatar || '/assets/images/default-avatar.jpg'}}"
            mode="aspectFill"
          />
          <image
            wx:else
            class="profile-avatar profile-avatar--placeholder"
            src="/assets/images/profile-icon.svg"
            mode="aspectFit"
          />
          <button
            wx:if="{{!isLoggedIn}}"
            class="profile-avatar-auth-btn"
            open-type="getPhoneNumber"
            bindgetphonenumber="onPhoneRegister"
          />
        </view>
        <view class="profile-name">{{userDisplayName}}</view>
        <view wx:if="{{userIdentity}}" class="profile-badge">{{userIdentity}}</view>
      </view>

      <!-- 奖励/课时卡片 -->
      <view class="profile-reward-section">
        <card>
          <view class="profile-reward-card">
            <view class="profile-reward-icon-wrap">
              <text class="profile-reward-icon-star">★</text>
            </view>
            <view class="profile-reward-text">
              <text class="profile-reward-label">剩余课时</text>
              <view class="profile-reward-value-row">
                <text class="profile-reward-star">★</text>
                <text class="profile-reward-num">{{isLoggedIn ? totalCourseHoursText : '—'}}</text>
                <text class="profile-reward-unit" wx:if="{{isLoggedIn}}">小时</text>
              </view>
            </view>
            <view class="profile-reward-btn" bindtap="handleRedeemTap">查看</view>
          </view>
        </card>
      </view>

      <!-- 菜单列表 -->
      <view class="profile-menu-card">
        <block wx:if="{{isCoach || isManager}}">
          <view  class="profile-menu-item" bindtap="handleCoachBookCourt" hover-class="profile-menu-item--hover">
            <view class="profile-menu-icon"><text class="profile-menu-icon-text">订</text></view>
            <text class="profile-menu-label">预约场地</text>
            <view class="profile-menu-sep" />
            <image src="/assets/images/arrow-green.svg" class="profile-menu-arrow" mode="aspectFit" />
          </view>
          <view class="profile-menu-divider" />
        </block>
        <view class="profile-menu-item" bindtap="goCourtOrders" hover-class="profile-menu-item--hover">
          <view class="profile-menu-icon"><text class="profile-menu-icon-text">订</text></view>
          <text class="profile-menu-label">订场历史</text>
          <view class="profile-menu-sep" />
          <image src="/assets/images/arrow-green.svg" class="profile-menu-arrow" mode="aspectFit" />
        </view>
        <view class="profile-menu-divider" />
        <view class="profile-menu-item" bindtap="goGoodsOrders" hover-class="profile-menu-item--hover">
          <view class="profile-menu-icon"><text class="profile-menu-icon-text">课</text></view>
          <text class="profile-menu-label">课程订单</text>
          <view class="profile-menu-sep" />
          <image src="/assets/images/arrow-green.svg" class="profile-menu-arrow" mode="aspectFit" />
        </view>
        <view class="profile-menu-divider" />
        <view class="profile-menu-item" bindtap="goCourseHours" hover-class="profile-menu-item--hover">
          <view class="profile-menu-icon"><text class="profile-menu-icon-text">时</text></view>
          <text class="profile-menu-label">我的课时</text>
          <view class="profile-menu-sep" />
          <image src="/assets/images/arrow-green.svg" class="profile-menu-arrow" mode="aspectFit" />
        </view>
        <view class="profile-menu-divider" />
        <block wx:if="{{isCoach}}">
          <view class="profile-menu-item" bindtap="goCoachHolds" hover-class="profile-menu-item--hover">
            <view class="profile-menu-icon"><text class="profile-menu-icon-text">场</text></view>
            <text class="profile-menu-label">我的场地占用</text>
            <view class="profile-menu-sep" />
            <image src="/assets/images/arrow-green.svg" class="profile-menu-arrow" mode="aspectFit" />
          </view>
          <view class="profile-menu-divider" />
        </block>
      </view>

      <view class="profile-footer-space" style="height: {{placeholderHeight}}px;"></view>
    </view>
  </scroll-view>
</view>
