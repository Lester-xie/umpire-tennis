<view class="admin-sub-page">
  <view class="header-wrapper">
    <header showBackButton="{{true}}" title="用户与角色" />
  </view>
  <scroll-view class="admin-scroll" scroll-y="true" style="height: {{scrollHeight}}px;">
    <view class="field">
      <text class="field-label">手机号</text>
      <input
        class="field-input"
        type="number"
        maxlength="11"
        placeholder="输入 11 位手机号后点查询"
        value="{{targetPhone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <button
      class="query-btn"
      type="default"
      loading="{{querying}}"
      disabled="{{querying}}"
      bindtap="onQueryUser"
    >查询</button>
    <text class="page-hint">先查询用户，再调整下方开关并保存。</text>

    <block wx:if="{{userCardVisible}}">
      <view class="user-card">
        <view class="user-card-main">
          <image
            class="user-avatar"
            src="{{avatarDisplayUrl}}"
            mode="aspectFill"
          />
          <view class="user-meta">
            <text class="user-name">{{userName || '未设置昵称'}}</text>
            <text class="user-phone">{{queriedPhone}}</text>
          </view>
        </view>

        <view class="switch-row">
          <text class="switch-label">教练</text>
          <switch checked="{{isCoach}}" bindchange="onToggleCoach" color="#134E35" />
        </view>
        <view class="commission-block" wx:if="{{isCoach}}">
          <text class="commission-label">上课分成比例</text>
          <view class="commission-field">
            <input
              class="commission-input"
              type="digit"
              maxlength="6"
              placeholder="5"
              value="{{coachCommissionInput}}"
              bindinput="onCoachCommissionInput"
            />
            <text class="commission-suffix">%</text>
          </view>
        </view>
        <view class="switch-row">
          <text class="switch-label">VIP</text>
          <switch checked="{{isVip}}" bindchange="onToggleVip" color="#134E35" />
        </view>
      </view>

      <button class="submit-btn" bindtap="onSubmit">保存角色</button>
    </block>
  </scroll-view>
</view>
