<view class="container">
  <header hideDesc="{{true}}" title="预订球场" />
  <view class="content" style="height: {{contentHeight}}px; padding-bottom: {{selectedSlots.length > 0 ? '140rpx' : '40rpx'}};">
    <view
      class="content-header"
      hover-class="content-header-title--hover"
      hover-start-time="20"
      hover-stay-time="100"
      bindtap="handleContentHeaderTitleTap"
    >
      <image class="content-header-icon" src="/assets/images/location.png" mode="aspectFit"></image>
      {{selectedVenueName}}
    </view>

    <scroll-view class="content-calendar" scroll-x="true" enable-flex="true">
      <view class="content-calendar-scroll">
        <view 
          class="content-calendar-item" 
          wx:for="{{dateList}}" 
          wx:key="dateStr"
          data-datestr="{{item.dateStr}}"
          bindtap="handleDateClick"
        >
          <view class="date-weekday">{{item.weekday}}</view>
          <view class="date-month-day {{selectedDate === item.dateStr ? 'active' : ''}} {{rippleDate === item.dateStr ? 'ripple' : ''}}">
            <view class="date-text">{{item.monthDay}}</view>
            <view class="ripple-effect" wx:if="{{rippleDate === item.dateStr}}"></view>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="content-time">
      <!-- 可滚动的区域 -->
      <scroll-view class="content-time-scroll" scroll-x="true" scroll-y="true" enable-flex="true" show-scrollbar="{{false}}">
        <view class="time-table">
          <!-- 第一行：时间列头部 + 场地头部 -->
          <view class="time-table-header">
            <!-- 固定的时间列头部 -->
            <view class="time-column-fixed">
              <view class="time-header-fixed"></view>
            </view>
            <!-- 固定的场地头部 -->
            <view class="court-header-row">
              <view class="court-header" wx:for="{{courts}}" wx:key="id">
                {{item.name}}
              </view>
            </view>
          </view>
          
          <!-- 内容行：时间列 + 场地内容 -->
          <view class="time-table-content">
            <!-- 固定的时间列 -->
            <view class="time-column-fixed">
              <view class="time-slot-fixed" wx:for="{{timeSlots}}" wx:key="time">
                {{item.time}}
              </view>
            </view>
            <!-- 可滚动的内容区域 -->
            <view class="court-content-row">
              <view class="court-column" wx:for="{{courts}}" wx:key="id">
                <view class="court-slots court-slots--stacked">
                  <block wx:for="{{item.slots}}" wx:for-item="slot" wx:for-index="slotIndex" wx:key="slotIndex">
                    <view 
                      wx:if="{{!slot.coachMergeSkip && slot.available}}"
                      class="time-slot-cell available {{selectedSlotsMap[item.id + '-' + slotIndex] ? 'active' : ''}} {{rippleSlot && rippleSlot.courtId === item.id && rippleSlot.slotIndex === slotIndex ? 'ripple' : ''}}"
                      style="{{slot.slotStyle}}"
                      data-courtid="{{item.id}}"
                      data-slotindex="{{slotIndex}}"
                      bindtap="handleSlotClick"
                    >
                      <view class="slot-text">
                        <text class="slot-price">¥ {{slot.price}}</text>
                      </view>
                      <view class="ripple-effect" wx:if="{{rippleSlot && rippleSlot.courtId === item.id && rippleSlot.slotIndex === slotIndex}}"></view>
                    </view>
                    <view 
                      wx:elif="{{!slot.coachMergeSkip && !slot.available}}"
                      class="time-slot-cell {{slot.past ? 'slot-past' : ''}} {{slot.booked ? 'slot-occupied' : ''}} {{slot.bookedByCoach ? 'slot-coach-hold' : ''}}"
                      style="{{slot.slotStyle}}"
                    >
                      <block wx:if="{{slot.bookedByCoach}}">
                        <view
                          class="slot-coach-inner"
                          catchtap="handleCoachHoldCellTap"
                          data-purpose="{{slot.coachPurpose}}"
                          data-holdids="{{slot.coachHoldIdsStr}}"
                          data-courtid="{{item.id}}"
                          data-slotindex="{{slotIndex}}"
                          data-span="{{slot.coachSpan}}"
                          data-lessontype="{{slot.prefillLessonType}}"
                          data-pairmode="{{slot.prefillPairMode}}"
                          data-groupmode="{{slot.prefillGroupMode}}"
                          data-coachname="{{slot.prefillCoachName}}"
                          data-sessionfull="{{slot.coachSessionFull}}"
                          data-viewerjoined="{{slot.coachViewerAlreadyJoined}}"
                          data-slotpast="{{slot.past ? 1 : 0}}"
                        >
                          <text class="slot-coach-purpose">{{slot.coachPurpose}}</text>
                          <text class="slot-coach-cap" wx:if="{{slot.coachCapacityLimit > 0}}">名额 {{slot.coachJoinedCount}}/{{slot.coachCapacityLimit}}</text>
                        </view>
                      </block>
                      <block wx:elif="{{slot.past}}">
                        <text class="slot-booked">不可预定</text>
                      </block>
                      <block wx:elif="{{slot.booked}}">
                        <text class="slot-booked">已订</text>
                      </block>
                      <block wx:else>
                        <text class="slot-booked">已约</text>
                      </block>
                    </view>
                  </block>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
    <view class="content-footer" wx:if="{{selectedSlots.length > 0}}">
      <view class="content-footer-left">
        合计：¥ {{totalPrice}}
      </view>
      <view class="content-footer-right">
        <view class="content-footer-right-button" bindtap="handleConfirmBooking">
          <text class="content-footer-right-button-text">下单</text>
        </view>
      </view>
    </view>
  </view>
</view>
