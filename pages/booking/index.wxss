.tab-row {
  display: flex;
  background: #ffffff;
  border-radius: 999rpx;
  padding: 6rpx;
  box-shadow: 0 10rpx 20rpx rgba(47, 91, 234, 0.08);
  gap: 6rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: #8a94a6;
}

.tab.active {
  background: #2f5bea;
  color: #ffffff;
}

.cover {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.slot-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 16rpx 0;
}

.slot {
  padding: 10rpx 16rpx;
  background: #f0f4ff;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #2f5bea;
}

.payment-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card-col {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
}

.price {
  color: #ff8b5e;
  font-weight: 600;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
