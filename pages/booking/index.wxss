.container {
  padding: 0 16px;
  display: flex;
  flex-direction: column;
  height: 100vh;
}
.content {
  box-sizing: border-box;
  margin-top: 10px;
  background-color: #F2F6F3;
  border-radius: 14px;
  padding: 10px;
  border: 1px solid #ffffff;
  display: flex;
  flex-direction: column;
  position: relative;
}
.content-header {
  display: flex;
  align-items: center;
  gap: 10px;
  color: #134E35;
}
.content-header-icon-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 40px;
  height: 40px;
  background-color: #fff;
  border-radius: 50%;
}
.content-header-icon {
  width: 25px;
  height: 25px;
  object-fit: contain;
}
.content-calendar {
  width: 100%;
  white-space: nowrap;
  margin-top: 10px;
}
.content-calendar-scroll {
  display: inline-flex;
  gap: 10px;
}
.content-calendar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.date-weekday {
  font-size: 12px;
  color: #4C4C4C;
}
.date-month-day {
  box-sizing: border-box;
  margin-top: 10px;
  font-size: 14px;
  width: 40px;
  height: 40px;
  background-color: rgba(255, 255, 255, 0.6);
  border: 1px solid #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  color: #4C4C4C;
  position: relative;
  overflow: hidden;
}
.date-month-day.active {
  border: 1px solid #134E35;
  background-color: rgba(19, 78, 53, 0.41);
  /* active 状态下禁用 transition，避免闪动 */
  transition: none;
}
.date-text {
  position: relative;
  z-index: 1;
}
.date-month-day.active.ripple {
  animation: activeScale 0.6s ease-out;
  /* 动画期间禁用 transition */
  transition: none;
}
/* 动画结束后，保持 active 状态，不触发 transition */
.date-month-day.active:not(.ripple) {
  transition: none;
}
@keyframes activeScale {
  0% {
    border: 0px solid #134E35;
    background-color: rgba(19, 78, 53, 0);
  }
  100% {
    border: 1px solid #134E35;
    background-color: rgba(19, 78, 53, 0.41);
  }
}
.ripple-effect {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  animation: ripple 0.6s ease-out;
}
@keyframes ripple {
  0% {
    width: 0;
    height: 0;
    background-color: rgba(19, 78, 53, 0.8);
    opacity: 1;
  }
  50% {
    background-color: rgba(19, 78, 53, 0.5);
  }
  100% {
    width: 80px;
    height: 80px;
    background-color: rgba(19, 78, 53, 0.2);
    opacity: 0;
  }
}
.content-time {
  width: 100%;
  flex: 1;
  min-height: 0;
  display: flex;
  position: relative;
}
.content-time-scroll {
  width: 100%;
  flex: 1;
}
.time-table {
  display: flex;
  flex-direction: column;
  min-width: 100%;
}
.time-table-header {
  display: flex;
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #F2F6F3;
  flex-shrink: 0;
}
.time-table-content {
  display: flex;

}
.time-column-fixed {
  position: sticky;
  left: 0;
  width: 50px;
  z-index: 9;
  background-color: #F2F6F3;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  padding-top: 4px;
}
.time-header-fixed {
  height: 40px;
  flex-shrink: 0;
}
.time-slot-fixed {
  height: 50px;
  font-size: 12px;
  color: #4C4C4C;
  padding-left: 4px;
  box-sizing: border-box;
  margin-bottom: 4px;

}
.court-header-row {
  display: flex;
  gap: 10px;
  background-color: #F0F6F4CC;
}
.court-header {
  flex: 1;
  min-width: 0;
  height: 50px;
  width: 60px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 14px;
  color: #134E35;
  font-weight: 500;
}
.court-content-row {
  display: flex;
  flex: 1;
  background-color: #FFF;
}
.court-column {
  margin-left: 4px;
  padding-top: 4px
}
.court-slots {
  display: flex;
  flex-direction: column;
}
.time-slot-cell {
  width: 60px;
  height: 50px;
  margin-bottom: 4px;
  background-color: #F5F5F5;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  /* 硬件加速优化 */
  transform: translateZ(0);
  will-change: border, background-color;
}
.time-slot-cell.available {
  background-color: #fff;
  border: 1px solid #E0E0E0;
  transition: border 0.2s ease, background-color 0.2s ease;
}
.time-slot-cell.available.active {
  border: 1px solid #134E35;
  background-color: rgba(19, 78, 53, 0.41);
  /* active 状态下禁用 transition，避免闪动 */
  transition: none;
}
.time-slot-cell.available.active.ripple {
  animation: slotActiveScale 0.6s ease-out;
  /* 动画期间启用硬件加速 */
  will-change: border, background-color;
  /* 动画期间禁用 transition */
  transition: none;
}
/* 动画结束后，保持 active 状态，不触发 transition */
.time-slot-cell.available.active:not(.ripple) {
  transition: none;
}
@keyframes slotActiveScale {
  0% {
    border: 0px solid #134E35;
    background-color: rgba(19, 78, 53, 0);
  }
  100% {
    border: 1px solid #134E35;
    background-color: rgba(19, 78, 53, 0.41);
  }
}
.slot-text {
  position: relative;
  z-index: 1;
}
.slot-price {
  font-size: 14px;
  color: #134E35;
}
.time-slot-cell.available.active .slot-price {
  color: #134E35;
}
.slot-booked {
  font-size: 12px;
  color: #999;
}
.content-footer {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  background-color: #fff;
  border-top: 1px solid #E0E0E0;
  border-radius: 0 0 14px 14px;
  box-shadow: 0 -2px 8px rgba(0, 0, 0, 0.05);
}
.content-footer-left {
  font-size: 14px;
  font-weight: 500;
  color: #134E35;
}
.content-footer-right {
  flex-shrink: 0;
}
.content-footer-right-button {
  background: linear-gradient(135deg, #134E35 0%, #1a6b4a 100%);
  border-radius: 20px;
  padding: 8px 20px;
  min-width: 80px;
  text-align: center;
  box-shadow: 0 4px 12px rgba(19, 78, 53, 0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}
.content-footer-right-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.5s ease;
}
.content-footer-right-button:active::before {
  left: 100%;
}
.content-footer-right-button:active {
  transform: scale(0.95);
  box-shadow: 0 2px 8px rgba(19, 78, 53, 0.3);
}
.content-footer-right-button-text {
  font-size: 13px;
  color: #fff;
  font-weight: 600;
  position: relative;
  z-index: 1;
  letter-spacing: 0.5px;
}