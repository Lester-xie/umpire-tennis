.hero-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
}

.hero-desc {
  font-size: 24rpx;
  color: #5a667a;
}

.cover {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.card-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.card-col {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
}

.tag-row {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}
