<view class="container">
  <view class="hero">
    <view class="hero-content">
      <text class="hero-title">活动报名</text>
      <text class="hero-desc">畅打 / 比赛 / 团课</text>
    </view>
    <view class="illustration">活力</view>
  </view>

  <view class="section-title">本期活动</view>
  <view class="card" wx:for="{{activities}}" wx:key="id">
    <view class="cover placeholder">{{item.coverText}}</view>
    <view class="card-row">
      <view class="card-col">
        <text class="card-title">{{item.title}}</text>
        <text class="muted">{{item.date}}</text>
        <view class="tag-row">
          <text class="pill">{{item.type}}</text>
          <text class="pill">{{item.status}}</text>
        </view>
      </view>
      <button class="btn-primary" bindtap="handleSignup">报名</button>
    </view>
  </view>
</view>
