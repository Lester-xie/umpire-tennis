<view class="container">
  <lottie-loading visible="{{lottieLoadingVisible}}" />
  <view class="header-wrapper">
    <header showBackButton="{{true}}" />
  </view>
  <scroll-view
    class="content-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    style="margin-top: {{headerHeight}}px; height: {{contentHeight}}px;"
  >
    <view class="content" wx:if="{{!loading && !errMsg}}">
      <card>
        <view class="hero-card">
          <view class="hero-title">{{capacityLabel}}</view>
          <view class="hero-sub" wx:if="{{coachName}}">教练 {{coachName}}</view>
          <view class="hero-meta">
            <text class="hero-meta-item">{{campusName}}</text>
            <text class="hero-meta-item">{{formattedDate}}</text>
            <text class="hero-meta-item">{{courtName}} · {{timeRange}}</text>
          </view>
        </view>
      </card>

      <view
        class="tip-card tip-card--warn"
        wx:if="{{lessonType === 'experience' && experienceParticipationReady && experienceParticipatedBefore}}"
      >
        您已参加过体验课，每个手机号只能参加一次。如需继续学习，请选择正课或咨询场馆。
      </view>

      <view class="divider"></view>
      <card>
        <view class="section">
          <view class="section-title">报名情况</view>
          <view class="cap-line">已报 <text class="cap-num">{{joinedCount}}</text> / {{capacityLimit}} 人</view>
          <view class="participant-list" wx:if="{{participants.length > 0}}">
            <view class="participant-item" wx:for="{{participants}}" wx:key="index">
              <image
                class="participant-avatar"
                src="{{item.avatarUrl ? item.avatarUrl : defaultAvatar}}"
                mode="aspectFill"
              />
              <text class="participant-name">{{item.displayName}}</text>
            </view>
          </view>
          <view class="empty-roster" wx:else>暂无</view>
        </view>
      </card>

      <view class="tip-card" wx:if="{{slotPast}}">
        该时段已开始或结束。
      </view>
      <view class="tip-card" wx:elif="{{sessionFull && !slotPast}}">
        本场名额已满，您可浏览其他时段或向场馆咨询加开。
      </view>
    </view>

    <view class="state-block" wx:if="{{loading}}">
      <text>加载中…</text>
    </view>
    <view class="state-block state-block--err" wx:if="{{errMsg}}">
      <text>{{errMsg}}</text>
    </view>
  </scroll-view>

  <view class="footer" wx:if="{{!loading && !errMsg && (canBook || canCancelEnrollment)}}">
    <view class="footer-btn" wx:if="{{canBook}}" bindtap="onBookTap">
      <text class="footer-btn-text">立即报名</text>
    </view>
    <view
      class="footer-btn footer-btn--outline"
      wx:if="{{canCancelEnrollment}}"
      bindtap="onCancelEnrollmentTap"
    >
      <text class="footer-btn-text footer-btn-text--outline">取消报名</text>
    </view>
  </view>
</view>
