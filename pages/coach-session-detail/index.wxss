.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  width: 100%;
  box-sizing: border-box;
}

.content {
  padding: 24rpx 32rpx 48rpx;
}

.hero-card {
  background: rgba(240, 246, 244, 0.8);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
  color: #134e35;
}

.hero-sub {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #3d5c4f;
  line-height: 1.4;
}

.hero-meta {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-meta-item {
  font-size: 24rpx;
  line-height: 1.4;
  color: #535353;
}

.section {
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  line-height: normal;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #134e35;
  margin-bottom: 20rpx;
}

.cap-line {
  font-size: 28rpx;
  color: #444;
  margin-bottom: 20rpx;
}

.cap-num {
  font-weight: 700;
  color: #134e35;
  font-size: 32rpx;
}

.participant-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 28rpx;
  color: #333;
}

.participant-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-sizing: border-box;
  border: 2rpx solid rgba(27, 67, 50, 0.18);
  background: #e8e8e8;
}

.empty-roster {
  font-size: 26rpx;
  color: #888;
}

.tip-card {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  padding: 20rpx 24rpx;
  background: rgba(45, 106, 79, 0.08);
  border-radius: 16rpx;
  border: 2rpx solid rgba(45, 106, 79, 0.15);
}

.tip-card--warn {
  margin-top: 24rpx;
  color: #92400e;
  background: rgba(251, 191, 36, 0.12);
  border-color: rgba(217, 119, 6, 0.35);
}

.state-block {
  padding: 120rpx 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
}

.state-block--err {
  color: #b45309;
}

.footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 2rpx solid #e0e0e0;
}

.footer-btn {
  height: 88rpx;
  border-radius: 44rpx;
  background: #2d6a4f;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-btn-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}

.footer-btn--outline {
  background: #ffaa00;
}

.footer-btn-text--outline {
  color: #fff;
}

.divider {
  margin-top: 20rpx;
}