.profile-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbefd0 0%, #dbefd0 55%, #dae4de 100%);
  box-sizing: border-box;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  width: 100%;
}

.content-wrapper {
  padding: 32rpx;
}

.hint-banner {
  font-size: 24rpx;
  color: #8a6d3b;
  line-height: 1.5;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: rgba(254, 243, 199, 0.55);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.card {
  background-color: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-card {
  margin-bottom: 24rpx;
}

.venue-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #134e35;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e8ece9;
}

.hour-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hour-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: #f7f9ff;
  border-radius: 20rpx;
}

.hour-label {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.hour-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #134e35;
  flex-shrink: 0;
}

.empty-tip {
  padding: 48rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-link {
  font-size: 28rpx;
  color: #134e35;
  font-weight: 500;
}

.link-card {
  margin-bottom: 32rpx;
  padding: 0;
  overflow: hidden;
}

.link-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}

.link-text {
  font-size: 28rpx;
  color: #134e35;
  font-weight: 500;
}

.link-arrow {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.5;
}

.placeholder {
  width: 100%;
}
