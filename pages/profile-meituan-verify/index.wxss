.verify-page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbefd0 0%, #dbefd0 55%, #dae4de 100%);
  box-sizing: border-box;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  width: 100%;
}

.content-wrapper {
  padding: 24rpx 32rpx 32rpx;
}

.intro-block {
  padding: 8rpx 8rpx 28rpx;
}

.intro-venue {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #134e35;
  margin-bottom: 8rpx;
}

.intro-desc {
  display: block;
  font-size: 24rpx;
  color: #5a7a66;
  line-height: 1.5;
}

.verify-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(19, 78, 53, 0.08);
}

.verify-card--empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 40rpx 48rpx;
  text-align: center;
}

.empty-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ecfdf5, #d1fae5);
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #134e35;
  margin-bottom: 12rpx;
}

.empty-desc {
  display: block;
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  margin-bottom: 36rpx;
}

.form-block {
  margin-bottom: 8rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 16rpx;
}

.form-divider {
  height: 2rpx;
  background: #f0f3f1;
  margin: 28rpx 0;
}

.platform-tabs {
  display: flex;
  gap: 20rpx;
}

.platform-tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 0;
  border-radius: 18rpx;
  background: #f7f9f8;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.platform-tab__name {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.platform-tab--on {
  background: #ecfdf5;
  border-color: #134e35;
  box-shadow: 0 4rpx 16rpx rgba(19, 78, 53, 0.1);
}

.platform-tab--on .platform-tab__name {
  font-weight: 600;
  color: #134e35;
}

.code-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  background: #f7f9f8;
  border-radius: 18rpx;
  border: 2rpx solid #eef2ef;
}

.code-box__input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 30rpx;
  color: #222;
}

.code-box__placeholder {
  color: #bbb;
  font-size: 28rpx;
}

.code-box__scan {
  flex-shrink: 0;
  padding: 16rpx 28rpx;
  background: #134e35;
  border-radius: 14rpx;
}

.code-box__scan-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.ticket-preview {
  margin-top: 28rpx;
  padding: 28rpx;
  background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 100%);
  border-radius: 20rpx;
  border: 2rpx solid #bbf7d0;
}

.ticket-preview__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.ticket-preview__platform {
  font-size: 22rpx;
  font-weight: 600;
  color: #134e35;
  padding: 6rpx 16rpx;
  background: rgba(19, 78, 53, 0.1);
  border-radius: 8rpx;
}

.ticket-preview__tag {
  font-size: 22rpx;
  color: #16a34a;
}

.ticket-preview__name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.ticket-preview__grant {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed rgba(19, 78, 53, 0.15);
}

.ticket-preview__grant-item {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.ticket-preview__grant-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #134e35;
  line-height: 1;
}

.ticket-preview__grant-unit {
  font-size: 24rpx;
  color: #134e35;
  font-weight: 500;
}

.ticket-preview__grant-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.ticket-preview__grant-label {
  font-size: 22rpx;
  color: #6b8f7a;
}

.ticket-preview__grant-type {
  font-size: 24rpx;
  color: #333;
  line-height: 1.4;
}

.alert {
  margin-top: 28rpx;
  padding: 24rpx 28rpx;
  border-radius: 18rpx;
  line-height: 1.55;
}

.alert--ok {
  background: #f0fdf4;
  border: 2rpx solid #bbf7d0;
}

.alert--ok .alert__text {
  color: #166534;
}

.alert--err {
  background: #fef2f2;
  border: 2rpx solid #fecaca;
}

.alert--err .alert__text {
  color: #991b1b;
}

.alert__text {
  font-size: 26rpx;
}

.btn-group {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn {
  margin: 0;
  padding: 0;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 88rpx;
}

.btn::after {
  border: none;
}

.btn--block {
  width: 100%;
}

.btn--ghost {
  background: #fff;
  color: #134e35;
  border: 2rpx solid #134e35;
}

.btn--primary {
  background: #134e35;
  color: #fff;
}

.btn[disabled] {
  opacity: 0.55;
}

.footnote {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #8aa896;
  margin-top: 28rpx;
  line-height: 1.5;
}

.footer-space {
  width: 100%;
}
