.hero-content {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  font-size: 36rpx;
  font-weight: 700;
}

.hero-desc {
  font-size: 24rpx;
  color: #5a667a;
}

.product {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(47, 91, 234, 0.06);
  flex: 1 1 45%;
}

.product-cover {
  width: 100%;
  height: 200rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
}

.product-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 12rpx 0 16rpx;
}

.price {
  color: #ff8b5e;
  font-weight: 600;
}
