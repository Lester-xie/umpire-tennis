<view class="container">
  <view class="hero">
    <view class="hero-content">
      <text class="hero-title">精选商城</text>
      <text class="hero-desc">球拍 · 网球 · 配件</text>
    </view>
    <view class="illustration">装备</view>
  </view>

  <view class="section-title">推荐商品</view>
  <view class="grid">
    <view class="product" wx:for="{{products}}" wx:key="id">
      <view class="product-cover placeholder">{{item.coverText}}</view>
      <text class="product-name">{{item.name}}</text>
      <view class="product-row">
        <text class="price">¥{{item.price}}</text>
        <text class="pill">{{item.tag}}</text>
      </view>
      <button class="btn-primary" bindtap="handleBuy">购买</button>
    </view>
  </view>
</view>
