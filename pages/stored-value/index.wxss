.stored-page {
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbefd0 0%, #dbefd0 55%, #dae4de 100%);
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.content-scroll {
  width: 100%;
}

.content-wrapper {
  padding: 24rpx 32rpx 32rpx;
}

.venue-bar {
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.venue-bar-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.venue-bar-label {
  font-size: 24rpx;
  color: #5a7a68;
}

.venue-bar-name {
  display: block;
  margin-top: 8rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #134e35;
}

.venue-switch {
  font-size: 26rpx;
  color: #134e35;
  padding: 12rpx 20rpx;
  border: 1rpx solid #c5ddd0;
  border-radius: 999rpx;
}

.hint-banner {
  font-size: 24rpx;
  color: #5a7a68;
  line-height: 1.5;
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 20rpx;
}

.plan-card {
  margin-bottom: 20rpx;
  padding: 32rpx 28rpx;
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.plan-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #134e35;
}

.plan-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #5a7a68;
}

.plan-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-top: 24rpx;
}

.plan-pay {
  font-size: 40rpx;
  font-weight: 700;
  color: #134e35;
}

.plan-credit {
  font-size: 26rpx;
  color: #2d6a4f;
}

.plan-btn {
  margin-top: 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #134e35;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.plan-btn--disabled {
  opacity: 0.45;
}

.empty-card {
  padding: 48rpx 32rpx;
  text-align: center;
  background: #fff;
  border-radius: 24rpx;
  color: #5a7a68;
  font-size: 28rpx;
}

.empty-link {
  display: inline-block;
  margin-top: 20rpx;
  color: #134e35;
  font-size: 28rpx;
}

.placeholder {
  width: 100%;
}
