.location-page {
  box-sizing: border-box;
  margin: 20rpx 32rpx;
  border-radius: 28rpx;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.map-wrap {
  height: 500rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
  border-radius: 28rpx;
  margin-bottom: 48rpx;
}

.venue-map {
  width: 100%;
  height: 100%;
}

.venue-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 球场列表项：与页面整体风格一致（圆角 28rpx、浅绿背景、柔和阴影） */
.list-item {
  display: flex;
  align-items: center;
}

.goods-item .goods-thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
  flex-shrink: 0;
  vertical-align: bottom;
}

.venue-thumb {
  background: linear-gradient(135deg, #E8EFEB 0%, #dbefd0 100%);
}

.goods-item .item-main {
  flex: 1;
  margin-left: 28rpx;
  min-width: 0;
}

.goods-item .item-desc {
  font-size: 30rpx;
  font-weight: 600;
  color: #134E35;
  line-height: 1.4;
}

.goods-item .item-time {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.45;
  white-space: normal;
  word-break: break-word;
  overflow-wrap: break-word;
}

.goods-item .item-time.venue-distance {
  color: #1a6b4a;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.item-inner {
  position: relative;
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
}

.item-current-badge {
  position: absolute;
  top: -1rpx;
  right: -1rpx;
  z-index: 1;
  padding: 12rpx 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  color: #fff;
  background: #134e35;
  border: 2rpx solid rgba(19, 78, 53, 0.35);
  line-height: 1.3;
  border-top-right-radius: 28rpx;
  border-bottom-left-radius: 28rpx;
}