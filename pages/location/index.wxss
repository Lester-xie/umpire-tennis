.location-page {
  box-sizing: border-box;
  padding: 0 16px 40px;
  background-color: #F2F6F3;
  margin: 10px 16px;
  border-radius: 14px;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 16px;
  box-sizing: border-box;
}

.map-wrap {
  margin: 0 -16px 24px;
  height: 220px;
  position: relative;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
}

.venue-map {
  width: 100%;
  height: 100%;
}

.venue-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

/* 球场列表项：与页面整体风格一致（圆角 14px、浅绿背景、柔和阴影） */
.list-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  background: #fff;
  border-radius: 14px;
  box-shadow: 0 2px 12px rgba(19, 78, 53, 0.08);
}
/* 当前选中项：参考 date-month-day.active */
.list-item.active {
  border: 1px solid #134E35;
}

.goods-item .goods-thumb {
  width: 56px;
  height: 56px;
  border-radius: 12px;
  flex-shrink: 0;
}

.venue-thumb {
  background: linear-gradient(135deg, #E8EFEB 0%, #dbefd0 100%);
}

.goods-item .item-main {
  flex: 1;
  margin-left: 14px;
  min-width: 0;
}

.goods-item .item-desc {
  font-size: 15px;
  font-weight: 600;
  color: #134E35;
  line-height: 1.4;
}

.goods-item .item-time {
  font-size: 12px;
  color: #666;
  margin-top: 4px;
}

.goods-item .item-time.venue-distance {
  color: #1a6b4a;
  font-size: 12px;
  margin-top: 2px;
}
