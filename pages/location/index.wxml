<view class="location-page">
  <lottie-loading visible="{{lottieLoadingVisible}}" />
  <view class="header-wrapper">
    <header hideDesc="{{true}}" title="{{headerTitle}}" />
  </view>
  <!-- 腾讯地图：展示球场与当前位置 -->
  <view class="map-wrap" style="margin-top: {{headerHeight + 10}}px;">
    <map
      id="venue-map"
      class="venue-map"
      latitude="{{mapLatitude}}"
      longitude="{{mapLongitude}}"
      scale="{{mapScale}}"
      markers="{{mapMarkers}}"
      show-location="{{false}}"
    />
  </view>
  <view class="venue-list">
    <view
      class="list-item goods-item {{selectedVenueId === item.id ? 'active' : ''}}"
      wx:for="{{venues}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onSelectVenue"
    >
      <image class="goods-thumb venue-thumb" src="{{item.image}}" mode="aspectFill" />
      <view class="item-main">
        <view class="item-desc">{{item.name}}</view>
        <view class="item-time">{{item.address}}</view>
        <view class="item-time venue-distance" wx:if="{{item.distanceText}}">距您 {{item.distanceText}}</view>
      </view>
    </view>
  </view>
</view>
