.complete-profile-page {
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbefd0 0%, #dbefd0 40%, #dae4de 100%);
  box-sizing: border-box;
  padding: 0 32rpx;
}

.content {
  padding: 48rpx 0;
}

.form-row {
  display: flex;
  align-items: center;
  margin-bottom: 48rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.form-label {
  width: 144rpx;
  font-size: 30rpx;
  color: #333;
  flex-shrink: 0;
}

/* 昵称输入框容器：聚焦时高亮 */
.form-row-nickname.form-row-focus .nickname-input {
  border-color: #134E35;
  background: #fff;
  box-shadow: 0 0 0 4rpx rgba(19, 78, 53, 0.12);
}

.nickname-input {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  padding: 0 32rpx;
  font-size: 32rpx;
  line-height: 88rpx;
  color: #134E35;
  letter-spacing: 1rpx;
  border: 3rpx solid #E8EFEB;
  border-radius: 24rpx;
  box-sizing: border-box;
  background: #F7FBF8;
  transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
}

.nickname-placeholder {
  color: #B0C4B8;
  font-size: 30rpx;
}

.avatar-btn {
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  width: 128rpx !important;
  height: 128rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-left: 0rpx !important;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 128rpx;
  height: 128rpx;
  display: block;
  background: linear-gradient(135deg, #F2F6F3 0%, #E8EFEB 100%);
  border-radius: 50%;
  border: 4rpx solid #E8EFEB;
}

.form-value {
  flex: 1;
  min-width: 0;
}

.phone-auth-btn {
  margin-left: 32rpx !important;
  padding: 20rpx 32rpx;
  font-size: 28rpx;
  color: #134E35;
  background-color: #F2F6F3;
  border: 2rpx solid #134E35;
  border-radius: 16rpx;
}

.phone-auth-btn::after {
  border: none;
}

.phone-done {
  font-size: 28rpx;
  color: #134E35;
}

.phone-input {
  flex: 1;
  width: 100%;
  min-width: 0;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border: 2rpx solid #E0E0E0;
  border-radius: 16rpx;
  box-sizing: border-box;
  background: #F7F9FF;
}

.submit-wrap {
  margin-top: 80rpx;
}

.submit-btn {
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  color: #fff;
  background: linear-gradient(135deg, #134E35 0%, #1a6b4a 100%);
  border-radius: 24rpx;
}
