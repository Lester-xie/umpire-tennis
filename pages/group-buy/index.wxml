<view class="container">
  <header hideDesc="{{true}}" showBackButton="{{true}}" />
  <scroll-view class="content" scroll-y="true" style="height: {{contentScrollHeight}}px;">
    <view class="goods-list">
      <view class="goods-item" wx:for="{{goods}}" wx:key="index" data-index="{{index}}" bindtap="handleGoodClick">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="goods-info">
          <view class="goods-desc">{{item.desc}}</view>
          <view class="goods-price">¥ {{item.price}}</view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
