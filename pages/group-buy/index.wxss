.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 32rpx;
}

.content {
  box-sizing: border-box;
  padding: 20rpx 0;
}

.goods-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.goods-item {
  display: flex;
  align-items: center;
  background-color: rgba(240, 246, 244, 0.8);
  border-radius: 28rpx;
  padding: 24rpx;
  border: 2rpx solid #ffffff;
  overflow: hidden;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 32rpx;
}

.goods-desc {
  font-size: 30rpx;
  color: #2d5016;
  line-height: 1.4;
}

.goods-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #2d5016;
  margin-top: 16rpx;
}
