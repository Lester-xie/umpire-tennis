.admin-sub-page {
  min-height: 100vh;
  background: #f7f9ff;
}

.header-wrapper {
  position: relative;
  z-index: 2;
  padding-left: 32rpx;
  padding-right: 32rpx;
  box-sizing: border-box;
}

.admin-scroll {
  box-sizing: border-box;
  padding: 24rpx 32rpx 48rpx;
}

.picker-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e8ecf4;
  margin-bottom: 20rpx;
}

.picker-label {
  font-size: 28rpx;
  color: #333;
}

.picker-value {
  font-size: 28rpx;
  color: #134e35;
}

.submit-btn {
  background: #134e35;
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  margin-bottom: 32rpx;
}

.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid #e8ecf4;
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.stats-row--total {
  border-top: 1rpx solid #eee;
  margin-top: 8rpx;
  padding-top: 20rpx;
  font-weight: 600;
}

.stats-k {
  color: #666;
}

.stats-v {
  color: #1a1a1a;
}

.warn {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #b45309;
  line-height: 1.4;
}

.hint {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}
