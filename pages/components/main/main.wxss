.main-container {
  display: flex;
  gap: 20px;
  margin-top: 20px;
}
.main-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #F0F6F4CC;
  border-radius: 14px;
  padding: 10px;
  border: 1px solid #ffffff;
}
.main-item-image-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50px;
  width: 50px;
  border-radius: 50%;
  background-color: #9fd356;
  padding: 10px;
}
.main-item-image {
  width: 40px;
  height: 40px;
  object-fit: contain;
}
.main-item-title {
  font-family: 'Impact', 'Haettenschweiler', 'Arial Narrow Bold', sans-serif;
  font-size: 16px;
  font-weight: 500;
  margin-top: 10px;
  color: #2d5016
}