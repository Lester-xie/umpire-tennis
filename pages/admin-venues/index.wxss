.admin-sub-page {
  min-height: 100vh;
  background: #f7f9ff;
}

.header-wrapper {
  position: relative;
  z-index: 2;
  padding-left: 32rpx;
  padding-right: 32rpx;
  box-sizing: border-box;
}

.admin-scroll {
  box-sizing: border-box;
  padding: 24rpx 32rpx 48rpx;
}

.add-btn {
  margin-bottom: 24rpx;
  background: #134e35;
  color: #fff;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.muted {
  font-size: 26rpx;
  color: #888;
  padding: 16rpx 0;
}

.venue-row {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.venue-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e8ecf4;
  min-width: 0;
}

.venue-main--hover {
  opacity: 0.92;
}

.venue-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.venue-meta {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  line-height: 1.4;
}

.venue-del {
  display: flex;
  align-items: center;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #c62828;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid rgba(198, 40, 40, 0.35);
}

.footer-space {
  height: 40rpx;
}
