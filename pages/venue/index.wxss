.venue-page {
  min-height: 100vh;
  background: #ffffff;
  padding: 24rpx;
}

.venue-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  margin: 16rpx 0 24rpx;
}

.venue-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.venue-card {
  border-radius: 26rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 24rpx rgba(31, 42, 68, 0.12);
  background: #ffffff;
}

.venue-cover {
  width: 100%;
  height: 280rpx;
  font-size: 24rpx;
}

.venue-content {
  padding: 18rpx 20rpx 24rpx;
}

.venue-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.venue-location {
  color: #8a94a6;
  font-size: 24rpx;
}

.venue-meta {
  display: flex;
  gap: 8rpx;
  margin: 12rpx 0;
}

.venue-distance {
  color: #9aa3b3;
  font-size: 22rpx;
}
