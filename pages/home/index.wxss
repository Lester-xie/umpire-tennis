.home-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  width: 100%;
  margin-top: 0;
  box-sizing: border-box;
}

.content-wrapper {
  padding: 0 32rpx;
  min-height: 100%;
}

.stored-value-entry-container {
  margin-top: 40rpx;
}

.stored-value-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 0;
  padding: 28rpx 32rpx;
  gap: 24rpx;
}

.stored-value-entry-main {
  flex: 1;
  min-width: 0;
}

.stored-value-entry-img {
  width: 160rpx;
  height: 120rpx;
  flex-shrink: 0;
}

.stored-value-entry--hover {
  opacity: 0.92;
}

.stored-value-entry-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #134e35;
}

