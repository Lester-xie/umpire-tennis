.profile-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: linear-gradient(to bottom, #dbefd0 0%, #dbefd0 55%, #dae4de 100%);
  box-sizing: border-box;
}

.header-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.content-scroll {
  flex: 1;
  width: 100%;
}

.content-wrapper {
  padding: 32rpx;
}

.card {
  background-color: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-card {
  margin-bottom: 32rpx;
}

.section-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.goods-order-block {
  background-color: #f7f9ff;
  border-radius: 20rpx;
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: transparent;
  border-radius: 0;
}

.goods-refund-btn {
  padding: 16rpx 24rpx 22rpx;
  text-align: right;
  font-size: 26rpx;
  color: #92400e;
  border-top: 2rpx solid rgba(0, 0, 0, 0.06);
  background: rgba(251, 191, 36, 0.08);
}

.goods-item .goods-thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.goods-item .item-main {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.goods-item .item-desc {
  font-size: 28rpx;
  color: #134e35;
  line-height: 1.4;
}

.goods-item .item-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.item-price {
  font-size: 30rpx;
  font-weight: 600;
  color: #134e35;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.empty-tip {
  padding: 48rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.empty-link {
  font-size: 28rpx;
  color: #134e35;
  font-weight: 500;
}

.placeholder {
  width: 100%;
}
