<view class="profile-container">
  <view class="header-wrapper">
    <header hideDesc="{{true}}" showBackButton="{{true}}" title="课程订单" />
  </view>
  <scroll-view
    class="content-scroll"
    scroll-y="true"
    enhanced="{{true}}"
    show-scrollbar="{{false}}"
    style="margin-top: {{headerHeight}}px; height: {{contentHeight}}px;"
  >
    <view class="content-wrapper">
      <view class="card section-card">
        <view class="section-list" wx:if="{{goodsOrders.length > 0}}">
          <view class="list-item goods-item" wx:for="{{goodsOrders}}" wx:key="orderNumber">
            <image class="goods-thumb" src="{{item.goodItem.image}}" mode="aspectFill"></image>
            <view class="item-main">
              <view class="item-desc">{{item.goodItem.desc}}</view>
              <view class="item-time">{{item.formattedTime}}</view>
            </view>
            <view class="item-price">¥ {{item.totalPrice}}</view>
          </view>
        </view>
        <view class="empty-tip" wx:else>
          <text>暂无团购记录</text>
          <navigator class="empty-link" url="/pages/group-buy/index">去团购</navigator>
        </view>
      </view>
      <view class="placeholder" style="height: {{placeholderHeight}}px;"></view>
    </view>
  </scroll-view>
</view>
