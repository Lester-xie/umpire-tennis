.container {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.content-scroll {
  margin-top: 20rpx;
  flex-shrink: 0;
}

.content {
  background-color: #F2F6F3;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 160rpx;
  display: flex;
  flex-direction: column;
}

/* 商品订单 */
.goods-order {
  display: flex;
  flex-direction: column;
}
.goods-order-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}
.goods-order-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}
.goods-order-info {
  flex: 1;
  margin-left: 32rpx;
}
.goods-order-desc {
  font-size: 30rpx;
  color: #134E35;
  line-height: 1.4;
}
.goods-order-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #134E35;
  margin-top: 16rpx;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid #E0E0E0;
}
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.info-label {
  font-size: 28rpx;
  color: #666;
}
.info-value {
  font-size: 28rpx;
  color: #134E35;
  font-weight: 500;
}
.court-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}
.court-item {
  padding: 32rpx;
  background-color: #fff;
  border-radius: 16rpx;
}
.court-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #E0E0E0;
}
.court-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #134E35;
}
.court-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #134E35;
}
.time-slot-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.time-slot-item {
  background-color: #F2F6F3;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.time-slot-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.time-slot-time {
  font-size: 26rpx;
  color: #134E35;
  font-weight: 500;
}
.time-slot-hours {
  font-size: 24rpx;
  color: #999;
  background-color: rgba(19, 78, 53, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.time-slot-price {
  font-size: 28rpx;
  color: #134E35;
  font-weight: 500;
}
.fee-detail {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 2rpx solid #E0E0E0;
}
.fee-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.fee-item.total {
  padding-top: 24rpx;
  border-top: 2rpx solid #F0F0F0;
}
.fee-label {
  font-size: 28rpx;
  color: #666;
}
.fee-item.total .fee-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #134E35;
}
.fee-value {
  font-size: 28rpx;
  color: #134E35;
  font-weight: 500;
}
.fee-item.total .fee-value {
  font-size: 36rpx;
  font-weight: 600;
}
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 2rpx solid #E0E0E0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.footer-left {
  flex: 1;
}
.footer-total {
  font-size: 32rpx;
  font-weight: 500;
  color: #134E35;
}
.footer-right {
  flex-shrink: 0;
  margin-left: 24rpx;
}
.footer-button {
  background: linear-gradient(135deg, #134E35 0%, #1a6b4a 100%);
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
  min-width: 160rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(19, 78, 53, 0.3);
  position: relative;
  overflow: hidden;
}
.footer-button:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(19, 78, 53, 0.3);
}
.footer-button-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 手机号授权弹窗（与 profile 一致） */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal {
  width: 560rpx;
  background-color: #fff;
  border-radius: 28rpx;
  padding: 48rpx;
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.login-modal-desc {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.login-modal-btns {
  display: flex;
  gap: 24rpx;
}

.login-modal-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 20rpx;
  border: none;
  margin: 0;
}

.login-modal-btn::after {
  border: none;
}

.login-modal-btn.cancel {
  background-color: #F0F0F0;
  color: #666;
}

.login-modal-btn.confirm {
  background: linear-gradient(135deg, #134E35 0%, #1a6b4a 100%);
  color: #fff;
  font-weight: 500;
}
