.container {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.content-scroll {
  margin-top: 20rpx;
  flex-shrink: 0;
}

.content {
  background-color: #F2F6F3;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 160rpx;
  display: flex;
  flex-direction: column;
}

/* 商品订单 */
.goods-order {
  display: flex;
  flex-direction: column;
}
/* 与首页 components/goods 的 .goods-item 视觉一致 */
.goods-order-item {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  background-color: #ffffff;
  border-radius: 36rpx;
  padding: 32rpx;
  overflow: hidden;
}
.goods-order-main {
  display: flex;
  align-items: stretch;
  width: 100%;
}
.goods-order-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 36rpx;
  flex-shrink: 0;
  align-self: flex-start;
}
.goods-order-info {
  flex: 1;
  min-width: 0;
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-around;
}
.goods-order-desc {
  font-size: 34rpx;
  color: #000000;
  line-height: 1.4;
}
.goods-venue-section {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 2rpx solid #e8ece9;
  width: 100%;
  box-sizing: border-box;
}
.goods-venue-section-label {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}
.goods-venue-section-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  color: #134e35;
  font-weight: 600;
  line-height: 1.35;
}
.goods-venue-section-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #8a6d3b;
  line-height: 1.5;
  padding: 16rpx 20rpx;
  background: rgba(254, 243, 199, 0.45);
  border-radius: 16rpx;
}
.goods-grant-hours {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #2d6a4f;
  line-height: 1.45;
}
.goods-grant-hours--warn {
  color: #b45309;
}
.goods-order-price {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  border-top: 2rpx solid #e0e0e0;
  padding-top: 12rpx;
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 500;
  color: #414141;
}

.order-info {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid #E0E0E0;
}
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.info-label {
  font-size: 28rpx;
  color: #666;
}
.info-value {
  font-size: 28rpx;
  color: #134E35;
  font-weight: 500;
}

.coach-pay-panel {
  margin-bottom: 32rpx;
  padding: 28rpx;
  background: rgba(240, 246, 244, 0.85);
  border-radius: 24rpx;
  border: 2rpx solid #ffffff;
}
.coach-pay-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #134e35;
  margin-bottom: 12rpx;
}
.coach-balance-banner {
  margin-bottom: 20rpx;
  padding: 20rpx 22rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid #e8efe9;
}
.coach-balance-banner-main {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 8rpx 12rpx;
}
.coach-balance-banner-label {
  font-size: 26rpx;
  color: #555;
  margin-right: 8rpx;
}
.coach-balance-banner-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #134e35;
  line-height: 1;
}
.coach-balance-banner-unit {
  font-size: 26rpx;
  color: #134e35;
  font-weight: 500;
}
.coach-balance-banner-hint {
  font-size: 26rpx;
  color: #666;
  line-height: 1.4;
  flex: 1;
  min-width: 200rpx;
}
.coach-balance-banner-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #888;
  line-height: 1.45;
}
.coach-pay-hint {
  font-size: 24rpx;
  color: #666;
  line-height: 1.45;
  margin-bottom: 20rpx;
}
.coach-roster-card {
  margin-bottom: 20rpx;
  padding: 20rpx 22rpx;
  background: #fff;
  border-radius: 20rpx;
  border: 2rpx solid #e8efe9;
}
.coach-roster-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.coach-roster-row:last-of-type {
  margin-bottom: 0;
}
.coach-roster-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #666;
}
.coach-roster-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #134e35;
}
.coach-roster-names {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  line-height: 1.45;
}
.coach-roster-warn {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #b45309;
  line-height: 1.4;
}
.coach-pay-option {
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
}
.coach-pay-option:last-of-type {
  margin-bottom: 0;
}
.coach-pay-option--on {
  border-color: #2d6a4f;
  background: rgba(45, 106, 79, 0.08);
}
.coach-pay-option-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #222;
}
.coach-pay-option-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}
.coach-pay-warn {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #b45309;
  line-height: 1.45;
}

.court-list {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}
.court-item {
  padding: 32rpx;
  background-color: #fff;
  border-radius: 16rpx;
}
.court-item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #E0E0E0;
}
.court-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #134E35;
}
.court-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #134E35;
}
.time-slot-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.time-slot-item {
  background-color: #F2F6F3;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.time-slot-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.time-slot-time {
  font-size: 26rpx;
  color: #134E35;
  font-weight: 500;
}
.time-slot-hours {
  font-size: 24rpx;
  color: #999;
  background-color: rgba(19, 78, 53, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.time-slot-price {
  font-size: 28rpx;
  color: #134E35;
  font-weight: 500;
}
.fee-detail {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 40rpx;
  padding-top: 40rpx;
  border-top: 2rpx solid #E0E0E0;
}
.fee-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.fee-item.total {
  padding-top: 24rpx;
  border-top: 2rpx solid #F0F0F0;
}
.fee-label {
  font-size: 28rpx;
  color: #666;
}
.fee-item.total .fee-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #134E35;
}
.fee-value {
  font-size: 28rpx;
  color: #134E35;
  font-weight: 500;
}
.fee-item.total .fee-value {
  font-size: 36rpx;
  font-weight: 600;
}
.fee-item.coach-fee-note .fee-label,
.fee-item.coach-fee-note .fee-value {
  font-size: 24rpx;
  color: #888;
  font-weight: 400;
}
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  border-top: 2rpx solid #E0E0E0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
}
.footer-left {
  flex: 1;
}
.footer-total {
  font-size: 32rpx;
  font-weight: 500;
  color: #134E35;
}
.footer-right {
  flex-shrink: 0;
  margin-left: 24rpx;
}
.footer-button {
  background: linear-gradient(135deg, #134E35 0%, #1a6b4a 100%);
  border-radius: 40rpx;
  padding: 16rpx 40rpx;
  min-width: 160rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(19, 78, 53, 0.3);
  position: relative;
  overflow: hidden;
}
.footer-button:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(19, 78, 53, 0.3);
}
.footer-button-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* 手机号授权弹窗（与 profile 一致） */
.login-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.login-modal {
  width: 560rpx;
  background-color: #fff;
  border-radius: 28rpx;
  padding: 48rpx;
}

.login-modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.login-modal-desc {
  font-size: 30rpx;
  color: #666;
  text-align: center;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.login-modal-btns {
  display: flex;
  gap: 24rpx;
}

.login-modal-btn {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 20rpx;
  border: none;
  margin: 0;
}

.login-modal-btn::after {
  border: none;
}

.login-modal-btn.cancel {
  background-color: #F0F0F0;
  color: #666;
}

.login-modal-btn.confirm {
  background: linear-gradient(135deg, #134E35 0%, #1a6b4a 100%);
  color: #fff;
  font-weight: 500;
}
