<view class="container">
  <header hideDesc="{{true}}" showBackButton="{{true}}" />
  <scroll-view class="content-scroll" scroll-y="true" enhanced="{{true}}" show-scrollbar="{{false}}" style="height: {{contentScrollHeight}}px;">
  <view class="content">
    <!-- 商品订单 -->
    <block wx:if="{{orderType === 'goods'}}">
      <view class="goods-order" wx:if="{{goodItem}}">
        <view class="goods-order-item">
          <view class="goods-order-main">
            <image class="goods-order-image" src="{{goodItem.image}}" mode="aspectFill"></image>
            <view class="goods-order-info">
              <view class="goods-order-desc">{{goodItem.desc}}</view>
              <view class="goods-grant-hours" wx:if="{{goodItem.grantHours > 0 && goodItem.lessonKey}}">
                含可抵扣课时 {{goodItem.grantHours}} 小时
              </view>
              <view class="goods-grant-hours goods-grant-hours--warn" wx:elif="{{orderType === 'goods'}}">
                无法从课程识别可抵扣课时：请检查 categoryLabel（如体验课）、type（如1V1）、unit（如1h），或手动配置 grantHours、lessonKey
              </view>
              <view class="goods-order-price">¥ {{goodItem.price}}</view>
            </view>
          </view>
          <view class="goods-venue-section" wx:if="{{goodItem.venueName}}">
            <view class="goods-venue-section-label">所属场馆</view>
            <view class="goods-venue-section-value">{{goodItem.venueName}}</view>
            <view class="goods-venue-section-tip">不同场馆间的课程不可通用，请在对应场馆预约或使用。</view>
          </view>
        </view>
      </view>
      <view class="fee-detail">
        <view class="fee-item total">
          <text class="fee-label">合计</text>
          <text class="fee-value">¥ {{totalPrice}}</text>
        </view>
      </view>
    </block>

    <!-- 场地订单 -->
    <block wx:if="{{orderType === 'court'}}">
    <!-- 订单信息 -->
    <view class="order-info">
      <view class="info-item">
        <text class="info-label">预订日期</text>
        <text class="info-value">{{formattedDate}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">球馆</text>
        <text class="info-value">{{campusName}}</text>
      </view>
      <view class="info-item" wx:if="{{isCoachCourseOrder && coachCapacityLabel}}">
        <text class="info-label">课程</text>
        <text class="info-value">{{coachCapacityLabel}}</text>
      </view>
      <view class="info-item" wx:if="{{isCoachCourseOrder && coachName}}">
        <text class="info-label">教练</text>
        <text class="info-value">{{coachName}}</text>
      </view>
    </view>

    <!-- 教练时段：支付方式 -->
    <view class="coach-pay-panel" wx:if="{{isCoachCourseOrder}}">
      <view class="coach-pay-title">支付方式</view>
      <view class="coach-balance-banner">
        <view class="coach-balance-banner-main">
          <text class="coach-balance-banner-label">当前剩余课时</text>
          <block wx:if="{{coachCourseBalanceReady}}">
            <text class="coach-balance-banner-num">{{courseHoursBalance}}</text>
            <text class="coach-balance-banner-unit">小时</text>
          </block>
          <text wx:else class="coach-balance-banner-hint">{{coachCourseBalanceHint}}</text>
        </view>
        <text class="coach-balance-banner-tip">与本单课程类型、本场馆一致；不同场馆或课型不通用</text>
      </view>
      <view class="coach-pay-hint">本时段需消耗 {{requiredCourseHours}} 小时</view>
      <view class="coach-roster-card" wx:if="{{coachSessionRosterReady}}">
        <view class="coach-roster-row">
          <text class="coach-roster-label">课节名额</text>
          <text class="coach-roster-value">{{coachSessionJoined}} / {{coachSessionLimit}} 人</text>
        </view>
        <view class="coach-roster-row" wx:if="{{coachSessionParticipantNamesStr}}">
          <text class="coach-roster-label">已报名</text>
          <text class="coach-roster-names">{{coachSessionParticipantNamesStr}}</text>
        </view>
        <view class="coach-roster-warn" wx:if="{{coachSessionFull}}">名额已满，无法继续报名</view>
        <view class="coach-roster-warn" wx:elif="{{coachViewerAlreadyJoined}}">您已在名单中</view>
      </view>
      <view
        wx:if="{{courseHoursBalance >= requiredCourseHours}}"
        class="coach-pay-option {{payMethod === 'course_hours' ? 'coach-pay-option--on' : ''}}"
        data-method="course_hours"
        bindtap="selectPayMethod"
      >
        <text class="coach-pay-option-label">使用已购课时</text>
        <text class="coach-pay-option-desc">剩余 {{courseHoursBalance}} 小时</text>
      </view>
      <view
        wx:if="{{courseHoursBalance > 0 && courseHoursBalance < requiredCourseHours}}"
        class="coach-pay-option {{payMethod === 'mixed' ? 'coach-pay-option--on' : ''}}"
        data-method="mixed"
        bindtap="selectPayMethod"
      >
        <text class="coach-pay-option-label">组合支付</text>
        <text class="coach-pay-option-desc">先用课时 {{coachMixedPreviewDeduct}} 小时，余下 ¥{{coachMixedPreviewCash}} 微信付</text>
      </view>
      <view
        class="coach-pay-option {{payMethod === 'wechat' ? 'coach-pay-option--on' : ''}}"
        data-method="wechat"
        bindtap="selectPayMethod"
      >
        <text class="coach-pay-option-label">微信支付（全额）</text>
        <text class="coach-pay-option-desc">不扣课时，按场地标价 ¥{{totalPrice}}</text>
      </view>
      <view class="coach-pay-warn" wx:if="{{courseHoursBalance <= 0 && requiredCourseHours > 0}}">
        当前账号在本场馆暂无对应课时，请使用微信支付全额付款，或先购买课程后再用课时 / 组合支付
      </view>
    </view>
    
    <!-- 场地信息 -->
    <view class="court-list">
      <view class="court-item" wx:for="{{orderItems}}" wx:key="courtId">
        <view class="court-item-header">
          <text class="court-name">{{item.courtName}}</text>
          <text class="court-price">¥ {{item.totalPrice}}</text>
        </view>
        <view class="time-slot-list">
          <view class="time-slot-item" wx:for="{{item.timeSlots}}" wx:for-item="slot" wx:key="index">
            <view class="time-slot-info">
              <text class="time-slot-time">{{slot.timeRange}}</text>
              <text class="time-slot-hours">{{slot.hours}}小时</text>
            </view>
            <text class="time-slot-price">¥ {{slot.price}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 费用明细 -->
    <view class="fee-detail">
      <view class="fee-item" wx:if="{{!(isCoachCourseOrder && payMethod === 'mixed')}}">
        <text class="fee-label">场地费用</text>
        <text class="fee-value">¥ {{totalPrice}}</text>
      </view>
      <block wx:if="{{isCoachCourseOrder && payMethod === 'mixed'}}">
        <view class="fee-item">
          <text class="fee-label">课时抵扣</text>
          <text class="fee-value">{{coachHoursDeductForPay}} 小时</text>
        </view>
        <view class="fee-item">
          <text class="fee-label">微信支付（余下时段）</text>
          <text class="fee-value">¥ {{comboCashYuan}}</text>
        </view>
        <view class="fee-item coach-fee-note">
          <text class="fee-label">订单标价合计</text>
          <text class="fee-value">¥ {{totalPrice}}</text>
        </view>
      </block>
      <view class="fee-item total">
        <text class="fee-label">合计</text>
        <text class="fee-value" wx:if="{{isCoachCourseOrder && payMethod === 'course_hours'}}">课时 {{requiredCourseHours}} 小时</text>
        <text class="fee-value" wx:elif="{{isCoachCourseOrder && payMethod === 'mixed'}}">课时 {{coachHoursDeductForPay}} 小时 + ¥ {{comboCashYuan}}</text>
        <text class="fee-value" wx:else>¥ {{totalPrice}}</text>
      </view>
    </view>
    </block>
  </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="footer">
    <view class="footer-left">
      <text class="footer-total" wx:if="{{orderType === 'court' && isCoachCourseOrder && payMethod === 'course_hours'}}">使用课时 {{requiredCourseHours}} 小时</text>
      <text class="footer-total" wx:elif="{{orderType === 'court' && isCoachCourseOrder && payMethod === 'mixed'}}">课时 {{coachHoursDeductForPay}} 小时 + 微信 ¥{{comboCashYuan}}</text>
      <text class="footer-total" wx:else>合计：¥ {{totalPrice}}</text>
    </view>
    <view class="footer-right">
      <view class="footer-button" bindtap="handleSubmitOrder">
        <text class="footer-button-text">{{footerButtonText}}</text>
      </view>
    </view>
  </view>

  <!-- 未注册或无法静默登录时：手机号授权 -->
  <view class="login-modal-mask" wx:if="{{showPhoneAuthModal}}" catchtap="handleClosePhoneAuthModal">
    <view class="login-modal" catchtap="">
      <view class="login-modal-title">手机号登录</view>
      <view class="login-modal-desc">请先授权手机号；已注册用户将直接登录</view>
      <view class="login-modal-btns">
        <view class="login-modal-btn cancel" bindtap="handleClosePhoneAuthModal">取消</view>
        <button
          class="login-modal-btn confirm"
          open-type="getPhoneNumber"
          bindgetphonenumber="onPhoneRegister"
        >
          授权手机号
        </button>
      </view>
    </view>
  </view>
</view>
